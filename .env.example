# ============================================================
# unconcealment — environment variables
# Copy to .env and fill in values. Never commit .env.
# ============================================================

# --- Google Cloud (BigQuery) ---
# Your GCP project ID (required for billing even when querying public datasets)
GOOGLE_CLOUD_PROJECT=gen-lang-client-0170773691
# Path to service account key JSON, OR leave unset to use Application Default Credentials
# (run: gcloud auth application-default login)
GOOGLE_APPLICATION_CREDENTIALS=

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Postgres: Knowledge Graph (pgvector) ---
POSTGRES_KG_HOST=localhost
POSTGRES_KG_PORT=5433
POSTGRES_KG_DB=kg
POSTGRES_KG_USER=admin
POSTGRES_KG_PASSWORD=test1234

# --- Postgres: Temporal ---
POSTGRES_TEMPORAL_HOST=localhost
POSTGRES_TEMPORAL_PORT=5432
POSTGRES_TEMPORAL_DB=temporal
POSTGRES_TEMPORAL_USER=admin
POSTGRES_TEMPORAL_PASSWORD=test1234

# --- Temporal ---
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=unconcealment-indexing

# --- Apache Jena Fuseki ---
FUSEKI_URL=http://localhost:3030
FUSEKI_ADMIN_PASSWORD=test1234

# --- MinIO ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=test1234
MINIO_BUCKET=documents
MINIO_OBJECT_PREFIX=raw

# --- Java Backend ---
BACKEND_PORT=8080
MANIFEST_PATH=ontology/manifest.yaml

# --- Web Server ---
WEB_PORT=4321
BACKEND_URL=http://localhost:8080
# Must match manifest.yaml baseUri. For local dev this is the same as the web server —
# IRIs are dereferenceable URLs (http://localhost:4321/entity/{uuid} serves the entity page).
BASE_URI=http://localhost:4321
