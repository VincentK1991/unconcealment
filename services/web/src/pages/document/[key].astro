---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import MetaBox from "../../components/MetaBox.astro";
import ErrorAlert from "../../components/ErrorAlert.astro";

const { key: documentKey } = Astro.params;
if (!documentKey) return Astro.redirect("/");
const datasetId = Astro.url.searchParams.get("dataset") ?? "economic-census";

const BACKEND_URL = import.meta.env.BACKEND_URL ?? "http://localhost:8080";
const rawUrl = `${BACKEND_URL}/document/raw?dataset=${encodeURIComponent(datasetId)}&documentKey=${encodeURIComponent(documentKey)}`;

interface ResolvedPayload {
  objectKey?: string;
  contentType?: string;
  error?: string;
}

let resolved: ResolvedPayload | null = null;
let resolveError: string | null = null;

try {
  const res = await fetch(`${BACKEND_URL}/document/resolve?dataset=${encodeURIComponent(datasetId)}&documentKey=${encodeURIComponent(documentKey)}`);
  if (res.ok) {
    resolved = await res.json() as ResolvedPayload;
  } else {
    const body = await res.text();
    resolveError = `Backend returned ${res.status}: ${body}`;
  }
} catch {
  resolveError = "Backend unavailable";
}

const isPdf = (resolved?.contentType ?? "").toLowerCase().includes("pdf") || (resolved?.objectKey ?? "").toLowerCase().endsWith(".pdf");
---

<BaseLayout title={`Document ${documentKey} — unconcealment`} width="full">
  <div style="margin-bottom: 0.875rem;">
    <a class="link-subtle" style="font-size: 0.8125rem;" href={`/dataset/${encodeURIComponent(datasetId)}/documents`}>← Back to documents</a>
  </div>

  <h1
    style="font-family: 'Manrope', sans-serif; font-size: 1.5rem; font-weight: 800; color: #191c1e; letter-spacing: -0.02em; word-break: break-all; margin-bottom: 1rem;"
  >
    {documentKey}
  </h1>

  <MetaBox rows={[
    { key: "Dataset",      value: datasetId,                    code: true },
    { key: "Document key", value: documentKey,                  code: true },
    { key: "Object key",   value: resolved?.objectKey ?? "—",   code: true },
    { key: "Content type", value: resolved?.contentType ?? "—", code: true },
  ]} />

  {resolveError && <ErrorAlert message={resolveError} />}
  {!resolveError && !resolved && <ErrorAlert message="Unable to resolve document in MinIO." />}

  {!resolveError && resolved && (
    isPdf ? (
      <div
        style="border-radius: 1rem; overflow: hidden; box-shadow: 0px 4px 20px rgba(25,28,30,0.04), 0px 12px 40px rgba(18,74,240,0.06); height: calc(100vh - 220px); min-height: 500px;"
      >
        <iframe src={rawUrl} title={`PDF document ${documentKey}`} style="width: 100%; height: 100%; border: 0;" />
      </div>
    ) : (
      <div style="font-size: 0.875rem; color: #434656;">
        <p style="margin-bottom: 0.5rem;">This document is not a PDF.</p>
        <a href={rawUrl} target="_blank" rel="noreferrer" class="link-primary">Open raw file</a>
      </div>
    )
  )}
</BaseLayout>
