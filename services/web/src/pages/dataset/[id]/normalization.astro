---
export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import DatasetNav from "../../../components/DatasetNav.astro";
import NormalizationExplorer from "../../../components/NormalizationExplorer.tsx";

const { id: datasetId } = Astro.params;
if (!datasetId) return Astro.redirect("/");

const requestedPage = Math.max(1, Number.parseInt(Astro.url.searchParams.get("page") ?? "1", 10));
const normGraph = `urn:${datasetId}:normalization`;
---

<BaseLayout title={`Normalization — ${datasetId} — unconcealment`}>
  <DatasetNav datasetId={datasetId} current="normalization" />

  <div style="margin-bottom: 1.5rem;">
    <h1 style="font-family: 'Manrope', sans-serif; font-size: 1.75rem; font-weight: 800; color: #191c1e; letter-spacing: -0.025em; margin-bottom: 0.25rem;">
      Normalization
    </h1>
    <p style="font-size: 0.9rem; color: #434656; margin: 0 0 0.35rem;">
      Connected components from the normalization named graph, with canonical markers layered on top.
    </p>
    <code style="font-size: 0.7rem; color: #c4c5d9;">{normGraph}</code>
  </div>

  <NormalizationExplorer client:load datasetId={datasetId} initialPage={requestedPage} />
</BaseLayout>
