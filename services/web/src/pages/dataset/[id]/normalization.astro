---
export const prerender = false;

import DatasetNav from "../../../components/DatasetNav.astro";

const { id: datasetId } = Astro.params;
if (!datasetId) return Astro.redirect("/");

const BACKEND_URL = import.meta.env.BACKEND_URL ?? "http://localhost:8080";
const normGraph   = `urn:${datasetId}:normalization`;
const EX          = "https://kg.unconcealment.io/ontology/";

interface LabelBinding {
  entity: { value: string };
  label?: { value: string };
  slug?:  { value: string };
}

// Fetch canonicals and their aliases using the stored ex:isCanonical marker.
// The indexing pipeline elects one canonical per cluster at write-time;
// aliases are all other IRIs linked via owl:sameAs in either direction.
interface RowBinding {
  canonical: { value: string };
  alias?:    { value: string };
  method?:   { value: string };
  conf?:     { value: string };
}

const clusterSparql = `
  PREFIX owl: <http://www.w3.org/2002/07/owl#>
  PREFIX ex:  <${EX}>
  SELECT ?canonical ?alias ?method ?conf WHERE {
    GRAPH <${normGraph}> {
      ?canonical ex:isCanonical true .
      OPTIONAL {
        {
          ?canonical owl:sameAs ?alias .
          OPTIONAL {
            << ?canonical owl:sameAs ?alias >> ex:normalizationMethod ?method .
            << ?canonical owl:sameAs ?alias >> ex:confidence ?conf .
          }
        }
        UNION
        {
          ?alias owl:sameAs ?canonical .
          OPTIONAL {
            << ?alias owl:sameAs ?canonical >> ex:normalizationMethod ?method .
            << ?alias owl:sameAs ?canonical >> ex:confidence ?conf .
          }
        }
        FILTER(?alias != ?canonical)
      }
    }
  }
  ORDER BY DESC(?conf) ?canonical
  LIMIT 2000
`;

let rows: RowBinding[] = [];
let error: string | null = null;

try {
  const res = await fetch(`${BACKEND_URL}/query/raw?dataset=${encodeURIComponent(datasetId)}`, {
    method: "POST",
    headers: { "Content-Type": "application/sparql-query" },
    body: clusterSparql,
  });
  if (res.ok) {
    const data = await res.json() as { results?: { bindings?: RowBinding[] } };
    rows = data.results?.bindings ?? [];
  } else {
    error = `Backend returned ${res.status}`;
  }
} catch {
  error = "Backend unavailable";
}

// ── Group rows by canonical ───────────────────────────────────────────────────
interface Cluster {
  canonical: string;
  aliases:   string[];
  bestMethod?: string;
  bestConf?:   number;
}

const clusterMap = new Map<string, Cluster>();
for (const row of rows) {
  const c = row.canonical.value;
  if (!clusterMap.has(c)) clusterMap.set(c, { canonical: c, aliases: [] });
  const cluster = clusterMap.get(c)!;

  if (row.alias?.value && !cluster.aliases.includes(row.alias.value)) {
    cluster.aliases.push(row.alias.value);
  }
  const conf = parseFloat(row.conf?.value ?? "0");
  if (!isNaN(conf) && conf > (cluster.bestConf ?? 0)) {
    cluster.bestConf   = conf;
    cluster.bestMethod = row.method?.value;
  }
}

const clusters = Array.from(clusterMap.values())
  .sort((a, b) => b.aliases.length - a.aliases.length);

// ── Batch-fetch labels for all IRIs ──────────────────────────────────────────
const labelMap = new Map<string, { label?: string; slug?: string }>();

// ── Collect all IRIs for label batch-fetch ────────────────────────────────────
const allIriSet = new Set<string>();
for (const c of clusters) {
  allIriSet.add(c.canonical);
  for (const a of c.aliases) allIriSet.add(a);
}
const allIris = Array.from(allIriSet);

if (allIris.length > 0) {
  const values     = allIris.map(iri => `<${iri}>`).join(" ");
  const labelSparql = `
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    PREFIX ex:   <${EX}>
    SELECT ?entity ?label ?slug WHERE {
      GRAPH ?g {
        VALUES ?entity { ${values} }
        OPTIONAL { ?entity rdfs:label ?label }
        OPTIONAL { ?entity ex:slug    ?slug  }
      }
    }
  `;
  try {
    const res = await fetch(`${BACKEND_URL}/query/raw?dataset=${encodeURIComponent(datasetId)}`, {
      method: "POST",
      headers: { "Content-Type": "application/sparql-query" },
      body: labelSparql,
    });
    if (res.ok) {
      const data = await res.json() as { results?: { bindings?: LabelBinding[] } };
      for (const row of data.results?.bindings ?? []) {
        const iri = row.entity?.value;
        if (!iri) continue;
        const cur = labelMap.get(iri) ?? {};
        if (row.label?.value) cur.label = row.label.value;
        if (row.slug?.value)  cur.slug  = row.slug.value;
        labelMap.set(iri, cur);
      }
    }
  } catch { /* best-effort */ }
}

// Method counts across all clusters
const methodCounts: Record<string, number> = {};
for (const c of clusters) {
  const m = c.bestMethod ?? "unknown";
  methodCounts[m] = (methodCounts[m] ?? 0) + 1;
}

const iriTail     = (iri: string) => iri.split(/[/#]/).pop() ?? iri;
const displayName = (iri: string) => {
  const m = labelMap.get(iri);
  return m?.label ?? m?.slug ?? iriTail(iri);
};
const entityLink  = (iri: string) =>
  `/entity/${encodeURIComponent(datasetId)}/${encodeURIComponent(iriTail(iri))}`;

const methodBadge = (m: string | undefined): { label: string; color: string } => {
  if (m === "exact-label")  return { label: "exact",  color: "#d4edda" };
  if (m === "jaro-winkler") return { label: "fuzzy",  color: "#fff3cd" };
  if (m === "llm-judge")    return { label: "llm",    color: "#cce5ff" };
  return { label: m ?? "—", color: "#eee" };
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Normalization — {datasetId} — unconcealment</title>
    <style>
      body { font-family: system-ui, sans-serif; max-width: 960px; margin: 2rem auto; padding: 0 1rem; }
      h1 { font-size: 1.5rem; margin: 0 0 0.25rem; }
      .subtitle { color: #555; font-size: 0.9rem; margin: 0 0 1.25rem; font-family: monospace; }
      .summary { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
      .stat { background: #f8f8f8; border: 1px solid #e5e5e5; border-radius: 6px; padding: 0.45rem 0.8rem; font-size: 0.85rem; }
      .stat-n { font-weight: 600; font-size: 1rem; }
      table { width: 100%; border-collapse: collapse; margin-top: 0.5rem; }
      th { text-align: left; border-bottom: 2px solid #ccc; padding: 0.5rem 0.6rem; font-size: 0.8rem; color: #555; text-transform: uppercase; letter-spacing: 0.04em; }
      td { padding: 0.5rem 0.6rem; border-bottom: 1px solid #eee; vertical-align: top; }
      td:nth-child(3) { color: #777; font-size: 0.8rem; text-align: right; width: 4.5rem; }
      td:nth-child(4) { width: 6rem; }
      a { color: #1a6bb5; text-decoration: none; }
      a:hover { text-decoration: underline; }
      .canonical { font-weight: 500; }
      .badge { display: inline-block; border-radius: 3px; padding: 0.1rem 0.45rem; font-size: 0.72rem; font-weight: 500; }
      .alias-list { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-top: 0.25rem; }
      .alias-chip { display: inline-block; background: #f0f0f0; border: 1px solid #ddd; border-radius: 3px; padding: 0.1rem 0.4rem; font-size: 0.78rem; color: #1a6bb5; }
      .alias-chip:hover { background: #e3ecf8; border-color: #b3cde8; }
      .empty { color: #888; margin-top: 1rem; }
      .error { color: #c00; }
      .note { font-size: 0.78rem; color: #888; margin-top: 0.15rem; }
    </style>
  </head>
  <body>
    <DatasetNav datasetId={datasetId} current="normalization" />
    <h1>Normalization</h1>
    <p class="subtitle">{normGraph}</p>

    {error && <p class="error">{error}</p>}

    {clusters.length === 0 && !error && (
      <p class="empty">No normalization clusters found. Run the indexing pipeline to populate this graph.</p>
    )}

    {clusters.length > 0 && (
      <>
        <div class="summary">
          <div class="stat">
            <span class="stat-n">{clusters.length}</span><br/>clusters
          </div>
          <div class="stat">
            <span class="stat-n">{allIris.length}</span><br/>entities linked
          </div>
          {Object.entries(methodCounts).map(([m, n]) => {
            const b = methodBadge(m);
            return (
              <div class="stat">
                <span class="stat-n">{n}</span><br/>
                <span class="badge" style={`background:${b.color}`}>{b.label}</span>
              </div>
            );
          })}
        </div>

        <table>
          <thead>
            <tr>
              <th>Canonical entity</th>
              <th>Also known as</th>
              <th style="text-align:right">Conf.</th>
              <th>Method</th>
            </tr>
          </thead>
          <tbody>
            {clusters.map((c) => {
              const b    = methodBadge(c.bestMethod);
              const conf = c.bestConf != null
                ? `${Math.round(c.bestConf * 100)}%`
                : "—";
              return (
                <tr>
                  <td>
                    <a class="canonical" href={entityLink(c.canonical)}>
                      {displayName(c.canonical)}
                    </a>
                    <div class="note" title={c.canonical}>{iriTail(c.canonical)}</div>
                  </td>
                  <td>
                    <div class="alias-list">
                      {c.aliases.map(iri => (
                        <a class="alias-chip" href={entityLink(iri)}>
                          {displayName(iri)}
                        </a>
                      ))}
                    </div>
                  </td>
                  <td>{conf}</td>
                  <td><span class="badge" style={`background:${b.color}`}>{b.label}</span></td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </>
    )}
  </body>
</html>
