---
export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import DatasetNav from "../../../components/DatasetNav.astro";
import DataTable from "../../../components/DataTable.astro";
import Chip from "../../../components/Chip.astro";
import EmptyState from "../../../components/EmptyState.astro";

const { id: datasetId } = Astro.params;
if (!datasetId) return Astro.redirect("/");

const BACKEND_URL = import.meta.env.BACKEND_URL ?? "http://localhost:8080";

interface ClassBinding {
  class:    { value: string };
  label:    { value: string };
  comment?: { value: string };
  parent?:  { value: string };
}

interface PropBinding {
  prop:     { value: string };
  label:    { value: string };
  propType: { value: string };
  domain?:  { value: string };
  range?:   { value: string };
  comment?: { value: string };
}

const classSparql = `
  PREFIX owl:  <http://www.w3.org/2002/07/owl#>
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
  SELECT DISTINCT ?class ?label ?comment ?parent WHERE {
    ?class a owl:Class ;
           rdfs:label ?label .
    OPTIONAL { ?class rdfs:comment ?comment }
    OPTIONAL { ?class rdfs:subClassOf ?parent . FILTER(!isBlank(?parent)) }
  }
  ORDER BY ?label
`;

const propSparql = `
  PREFIX owl:  <http://www.w3.org/2002/07/owl#>
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
  SELECT DISTINCT ?prop ?label ?propType ?domain ?range ?comment WHERE {
    { ?prop a owl:ObjectProperty .   BIND("ObjectProperty"   AS ?propType) }
    UNION
    { ?prop a owl:DatatypeProperty . BIND("DatatypeProperty" AS ?propType) }
    ?prop rdfs:label ?label .
    OPTIONAL { ?prop rdfs:domain ?domain . FILTER(!isBlank(?domain)) }
    OPTIONAL { ?prop rdfs:range  ?range  . FILTER(!isBlank(?range))  }
    OPTIONAL { ?prop rdfs:comment ?comment }
  }
  ORDER BY ?label
`;

async function tboxQuery<T>(sparql: string): Promise<T[]> {
  try {
    const res = await fetch(`${BACKEND_URL}/query/tbox?dataset=${encodeURIComponent(datasetId)}`, {
      method: "POST",
      headers: { "Content-Type": "application/sparql-query" },
      body: sparql,
    });
    if (!res.ok) return [];
    const data = await res.json() as { results?: { bindings?: T[] } };
    return data.results?.bindings ?? [];
  } catch { return []; }
}

const [classes, props] = await Promise.all([
  tboxQuery<ClassBinding>(classSparql),
  tboxQuery<PropBinding>(propSparql),
]);

const short = (iri: string) => iri.split(/[/#]/).pop() ?? iri;
---

<BaseLayout title={`Ontology — ${datasetId} — unconcealment`}>
  <DatasetNav datasetId={datasetId} current="ontology" />

  <div style="margin-bottom: 1.5rem;">
    <h1 style="font-family: 'Manrope', sans-serif; font-size: 1.75rem; font-weight: 800; color: #191c1e; letter-spacing: -0.025em; margin-bottom: 0.25rem;">
      Ontology
    </h1>
    <code style="font-size: 0.7rem; color: #c4c5d9;">urn:{datasetId}:tbox:ontology</code>
  </div>

  <!-- Classes -->
  <div style="display: flex; align-items: baseline; gap: 0.5rem; margin-bottom: 0.75rem; margin-top: 1.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid rgba(196,197,217,0.3);">
    <h2 style="font-family: 'Manrope', sans-serif; font-size: 1.125rem; font-weight: 700; color: #191c1e;">Classes</h2>
    <span class="badge-count">{classes.length}</span>
  </div>
  {classes.length === 0
    ? <EmptyState message="No classes found." />
    : (
      <DataTable columns={["Class", "Parent", "Description"]}>
        {classes.map(row => (
          <tr>
            <td style="font-weight: 600;">{row.label.value}</td>
            <td style="font-size: 0.8125rem; color: #747688;">{row.parent ? short(row.parent.value) : "—"}</td>
            <td style="font-size: 0.8125rem; color: #434656;">{row.comment?.value ?? ""}</td>
          </tr>
        ))}
      </DataTable>
    )
  }

  <!-- Properties -->
  <div style="display: flex; align-items: baseline; gap: 0.5rem; margin-bottom: 0.75rem; margin-top: 2rem; padding-bottom: 0.5rem; border-bottom: 1px solid rgba(196,197,217,0.3);">
    <h2 style="font-family: 'Manrope', sans-serif; font-size: 1.125rem; font-weight: 700; color: #191c1e;">Properties</h2>
    <span class="badge-count">{props.length}</span>
  </div>
  {props.length === 0
    ? <EmptyState message="No properties found." />
    : (
      <DataTable columns={["Property", "Type", "Domain", "Range", "Description"]}>
        {props.map(row => (
          <tr>
            <td>
              <span style="font-weight: 600;">{row.label.value}</span>
              <br />
              <code style="font-size: 0.68rem; color: #c4c5d9;">{short(row.prop.value)}</code>
            </td>
            <td>
              <Chip
                label={row.propType.value === "ObjectProperty" ? "Object" : "Datatype"}
                variant={row.propType.value === "DatatypeProperty" ? "amber" : "blue"}
              />
            </td>
            <td style="font-family: ui-monospace, Menlo, Consolas, monospace; font-size: 0.75rem; color: #747688;">{row.domain ? short(row.domain.value) : "—"}</td>
            <td style="font-family: ui-monospace, Menlo, Consolas, monospace; font-size: 0.75rem; color: #747688;">{row.range  ? short(row.range.value)  : "—"}</td>
            <td style="font-size: 0.8125rem; color: #434656;">{row.comment?.value ?? ""}</td>
          </tr>
        ))}
      </DataTable>
    )
  }
</BaseLayout>
