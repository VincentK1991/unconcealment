---
export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import DatasetNav from "../../../components/DatasetNav.astro";
import DataTable from "../../../components/DataTable.astro";
import ErrorAlert from "../../../components/ErrorAlert.astro";
import EmptyState from "../../../components/EmptyState.astro";

const { id: datasetId } = Astro.params;
if (!datasetId) return Astro.redirect("/");

const BACKEND_URL = import.meta.env.BACKEND_URL ?? "http://localhost:8080";

const PAGE_SIZE = 25;
const page = Math.max(1, parseInt(Astro.url.searchParams.get("page") ?? "1", 10));
const q    = (Astro.url.searchParams.get("q") ?? "").trim();
const offset = (page - 1) * PAGE_SIZE;

interface EntityBinding {
  entity:   { value: string };
  label?:   { value: string };
  slug?:    { value: string };
  type?:    { value: string };
  comment?: { value: string };
}

const aboxAsserted = `urn:${datasetId}:abox:asserted`;

const escapeSparql = (s: string) => s.replace(/\\/g, "\\\\").replace(/"/g, '\\"');

const searchFilter = q
  ? `FILTER(CONTAINS(LCASE(STR(?label)), LCASE("${escapeSparql(q)}")))`
  : "";

const sparql = `
  PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
  PREFIX owl:  <http://www.w3.org/2002/07/owl#>
  PREFIX ex:   <https://kg.unconcealment.io/ontology/>
  SELECT DISTINCT ?entity ?label ?slug ?type (MIN(?c) AS ?comment) WHERE {
    GRAPH <${aboxAsserted}> {
      ?entity a ?type .
      OPTIONAL { ?entity rdfs:label ?label }
      OPTIONAL { ?entity ex:slug ?slug }
      OPTIONAL { ?entity rdfs:comment ?c }
      FILTER(?type != owl:NamedIndividual)
      ${searchFilter}
    }
  }
  GROUP BY ?entity ?label ?slug ?type
  ORDER BY ?label
  LIMIT ${PAGE_SIZE}
  OFFSET ${offset}
`;

const countSparql = `
  PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
  PREFIX owl:  <http://www.w3.org/2002/07/owl#>
  SELECT (COUNT(DISTINCT ?entity) AS ?total) WHERE {
    GRAPH <${aboxAsserted}> {
      ?entity a ?type .
      OPTIONAL { ?entity rdfs:label ?label }
      FILTER(?type != owl:NamedIndividual)
      ${searchFilter}
    }
  }
`;

let entities: EntityBinding[] = [];
let total = 0;
let error: string | null = null;

try {
  const [entitiesRes, countRes] = await Promise.all([
    fetch(`${BACKEND_URL}/query/raw?dataset=${encodeURIComponent(datasetId)}`, {
      method: "POST",
      headers: { "Content-Type": "application/sparql-query" },
      body: sparql,
    }),
    fetch(`${BACKEND_URL}/query/raw?dataset=${encodeURIComponent(datasetId)}`, {
      method: "POST",
      headers: { "Content-Type": "application/sparql-query" },
      body: countSparql,
    }),
  ]);
  if (entitiesRes.ok) {
    const data = await entitiesRes.json() as { results?: { bindings?: EntityBinding[] } };
    entities = data.results?.bindings ?? [];
  } else {
    error = `Backend returned ${entitiesRes.status}`;
  }
  if (countRes.ok) {
    const countData = await countRes.json() as { results?: { bindings?: Array<{ total?: { value: string } }> } };
    total = parseInt(countData.results?.bindings?.[0]?.total?.value ?? "0", 10);
  }
} catch {
  error = "Backend unavailable";
}

const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));

const shortLabel      = (iri: string) => iri.split(/[/#]/).pop() ?? iri;
const entityIdFromIri = (iri: string) => iri.split("/").pop() ?? iri;

const pageUrl = (p: number) => {
  const params = new URLSearchParams();
  if (q) params.set("q", q);
  params.set("page", String(p));
  return `?${params.toString()}`;
};

type PageItem = { kind: "page"; n: number } | { kind: "ellipsis" };
const paginationItems: PageItem[] = [];
if (totalPages > 1) {
  const pageNums = Array.from({ length: totalPages }, (_, i) => i + 1)
    .filter(p => p === 1 || p === totalPages || Math.abs(p - page) <= 2);
  for (let i = 0; i < pageNums.length; i++) {
    if (i > 0 && pageNums[i] - pageNums[i - 1] > 1) {
      paginationItems.push({ kind: "ellipsis" });
    }
    paginationItems.push({ kind: "page", n: pageNums[i] });
  }
}
---

<BaseLayout title={`Entities — ${datasetId} — unconcealment`}>
  <DatasetNav datasetId={datasetId} current="entities" />

  <div style="margin-bottom: 1.5rem;">
    <div style="display: flex; align-items: baseline; gap: 0.625rem; margin-bottom: 0.25rem;">
      <h1 style="font-family: 'Manrope', sans-serif; font-size: 1.75rem; font-weight: 800; color: #191c1e; letter-spacing: -0.025em;">
        Entities
      </h1>
      {total > 0 && <span class="badge-count">{total.toLocaleString()}</span>}
    </div>
    <code style="font-size: 0.7rem; color: #c4c5d9;">{aboxAsserted}</code>
  </div>

  {error && <ErrorAlert message={`Query failed: ${error}`} />}

  <!-- Search bar -->
  <form style="display: flex; gap: 0.5rem; margin-bottom: 1.25rem; max-width: 32rem;" method="get" action="">
    <div style="position: relative; flex: 1;">
      <span
        class="material-symbols-outlined"
        style="position: absolute; left: 0.75rem; top: 50%; transform: translateY(-50%); font-size: 1rem; color: #747688; pointer-events: none;"
      >
        search
      </span>
      <input
        type="search"
        name="q"
        value={q}
        placeholder="Search entities by label…"
        autocomplete="off"
        class="input-lucid"
        style="padding-left: 2.25rem;"
      />
    </div>
    <button type="submit" class="btn-primary-pill" style="padding: 0.5rem 1rem; font-size: 0.8125rem;">Search</button>
    {q && (
      <a href="?page=1" class="btn-ghost-sm" style="white-space: nowrap;">Clear</a>
    )}
  </form>

  {!error && entities.length === 0 && !q && (
    <EmptyState message={`No entities found. Run just trigger ${datasetId} to index a test document.`} />
  )}
  {!error && entities.length === 0 && q && (
    <EmptyState message={`No entities match "${q}".`} />
  )}

  {entities.length > 0 && (
    <>
      <p style="font-size: 0.75rem; color: #747688; margin-bottom: 0.75rem;">
        {q
          ? `${total.toLocaleString()} result${total !== 1 ? "s" : ""} for "${q}" — page ${page} of ${totalPages}`
          : `Page ${page} of ${totalPages} (${total.toLocaleString()} total)`
        }
      </p>

      <DataTable columns={["Label", "Type", "Description"]}>
        {entities.map(row => {
          const entityId = entityIdFromIri(row.entity.value);
          const label = row.label?.value ?? row.slug?.value ?? shortLabel(row.entity.value);
          const type  = row.type ? shortLabel(row.type.value) : "—";
          return (
            <tr>
              <td>
                <a class="link-primary" href={`/entity/${encodeURIComponent(datasetId)}/${encodeURIComponent(entityId)}`}>
                  {label}
                </a>
              </td>
              <td style="font-size: 0.8125rem; color: #747688;">{type}</td>
              <td style="font-size: 0.8125rem; color: #434656; max-width: 24rem;">{row.comment?.value ?? ""}</td>
            </tr>
          );
        })}
      </DataTable>

      <!-- Pagination -->
      {paginationItems.length > 0 && (
        <nav style="display: flex; flex-wrap: wrap; gap: 0.375rem; margin-top: 1.25rem;" aria-label="Pagination">
          {page > 1
            ? <a href={pageUrl(page - 1)} class="btn-ghost-sm">&#8249; Prev</a>
            : <span class="btn-ghost-sm disabled">&#8249; Prev</span>
          }

          {paginationItems.map(item =>
            item.kind === "ellipsis"
              ? <span class="btn-ghost-sm" style="pointer-events: none;">&#8230;</span>
              : item.n === page
                ? <span class="btn-ghost-sm active">{item.n}</span>
                : <a href={pageUrl(item.n)} class="btn-ghost-sm">{item.n}</a>
          )}

          {page < totalPages
            ? <a href={pageUrl(page + 1)} class="btn-ghost-sm">Next &#8250;</a>
            : <span class="btn-ghost-sm disabled">Next &#8250;</span>
          }
        </nav>
      )}
    </>
  )}
</BaseLayout>
