---
export const prerender = false;

import DatasetNav from "../../../components/DatasetNav.astro";

const { id: datasetId } = Astro.params;
if (!datasetId) return Astro.redirect("/");

const BACKEND_URL = import.meta.env.BACKEND_URL ?? "http://localhost:8080";

interface RuleBinding {
  rule:    { value: string };
  name:    { value: string };
  body:    { value: string };
  status:  { value: string };
  order:   { value: string };
}

async function fetchRules(graphUri: string): Promise<RuleBinding[]> {
  const sparql = `
    PREFIX ex: <https://kg.unconcealment.io/ontology/>
    PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
    SELECT ?rule ?name ?body ?status ?order WHERE {
      GRAPH <${graphUri}> {
        ?rule ex:ruleName   ?name ;
              ex:ruleBody   ?body ;
              ex:ruleStatus ?status ;
              ex:ruleOrder  ?order .
      }
    }
    ORDER BY ASC(xsd:integer(?order))
  `;
  try {
    const res = await fetch(`${BACKEND_URL}/query/raw?dataset=${encodeURIComponent(datasetId)}`, {
      method: "POST",
      headers: { "Content-Type": "application/sparql-query" },
      body: sparql,
    });
    if (!res.ok) return [];
    const data = await res.json() as { results?: { bindings?: RuleBinding[] } };
    return data.results?.bindings ?? [];
  } catch { return []; }
}

const forwardGraph  = `urn:${datasetId}:tbox:rules:forward`;
const backwardGraph = `urn:${datasetId}:tbox:rules:backward`;

const [forwardRules, backwardRules] = await Promise.all([
  fetchRules(forwardGraph),
  fetchRules(backwardGraph),
]);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Rules — {datasetId} — unconcealment</title>
    <style>
      body   { font-family: system-ui, sans-serif; max-width: 960px; margin: 2rem auto; padding: 0 1rem; }
      h1     { font-size: 1.5rem; margin: 0 0 0.25rem; }
      h2     { font-size: 1.1rem; margin: 2rem 0 0.75rem; border-bottom: 2px solid #e0e0e0; padding-bottom: 0.4rem; }
      .badge { display: inline-block; background: #f0f0f0; border-radius: 10px; padding: 0.1rem 0.55rem; font-size: 0.75rem; color: #555; margin-left: 0.4rem; }
      .graph { font-family: monospace; font-size: 0.8rem; color: #888; margin: 0 0 1rem; }
      .empty { color: #888; font-size: 0.9rem; }
      .rule  { border: 1px solid #e0e0e0; border-radius: 6px; margin-bottom: 0.75rem; overflow: hidden; }
      .rule__header {
        display: flex; align-items: center; gap: 0.75rem;
        padding: 0.6rem 1rem; background: #fafafa; border-bottom: 1px solid #e8e8e8;
      }
      .rule__order { font-size: 0.75rem; color: #aaa; min-width: 1.5rem; }
      .rule__name  { font-weight: 600; font-size: 0.9rem; flex: 1; }
      .rule__status-active     { font-size: 0.72rem; background: #e6f4ea; color: #276827; border-radius: 4px; padding: 0.1rem 0.45rem; }
      .rule__status-deprecated { font-size: 0.72rem; background: #f5f5f5; color: #888; border-radius: 4px; padding: 0.1rem 0.45rem; }
      .rule__body  { padding: 0.75rem 1rem; }
      pre  { margin: 0; font-size: 0.82rem; color: #222; white-space: pre-wrap; word-break: break-word; font-family: "SF Mono", "Fira Code", monospace; }
    </style>
  </head>
  <body>
    <DatasetNav datasetId={datasetId} current="rules" />
    <h1>Rules</h1>

    <!-- Forward Rules -->
    <h2 id="forward">
      Forward Rules
      <span class="badge">{forwardRules.length}</span>
      <span style="font-size:0.75rem;color:#888;font-weight:400;margin-left:0.5rem">materialized · RETE</span>
    </h2>
    <p class="graph">{forwardGraph}</p>

    {forwardRules.length === 0
      ? <p class="empty">No forward rules found in graph.</p>
      : forwardRules.map(r => (
          <div class="rule">
            <div class="rule__header">
              <span class="rule__order">#{r.order.value}</span>
              <span class="rule__name">{r.name.value}</span>
              <span class={r.status.value === "active" ? "rule__status-active" : "rule__status-deprecated"}>
                {r.status.value}
              </span>
            </div>
            <div class="rule__body">
              <pre>{r.body.value.trim()}</pre>
            </div>
          </div>
        ))
    }

    <!-- Backward Rules -->
    <h2 id="backward">
      Backward Rules
      <span class="badge">{backwardRules.length}</span>
      <span style="font-size:0.75rem;color:#888;font-weight:400;margin-left:0.5rem">query-time · LP</span>
    </h2>
    <p class="graph">{backwardGraph}</p>

    {backwardRules.length === 0
      ? <p class="empty">No backward rules found in graph.</p>
      : backwardRules.map(r => (
          <div class="rule">
            <div class="rule__header">
              <span class="rule__order">#{r.order.value}</span>
              <span class="rule__name">{r.name.value}</span>
              <span class={r.status.value === "active" ? "rule__status-active" : "rule__status-deprecated"}>
                {r.status.value}
              </span>
            </div>
            <div class="rule__body">
              <pre>{r.body.value.trim()}</pre>
            </div>
          </div>
        ))
    }
  </body>
</html>
