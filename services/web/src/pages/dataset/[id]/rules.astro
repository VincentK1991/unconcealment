---
export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import DatasetNav from "../../../components/DatasetNav.astro";
import EmptyState from "../../../components/EmptyState.astro";
import Chip from "../../../components/Chip.astro";

const { id: datasetId } = Astro.params;
if (!datasetId) return Astro.redirect("/");

const BACKEND_URL = import.meta.env.BACKEND_URL ?? "http://localhost:8080";

interface RuleBinding {
  rule:    { value: string };
  name:    { value: string };
  body:    { value: string };
  status:  { value: string };
  order:   { value: string };
}

async function fetchRules(graphUri: string): Promise<RuleBinding[]> {
  const sparql = `
    PREFIX ex: <https://kg.unconcealment.io/ontology/>
    PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
    SELECT ?rule ?name ?body ?status ?order WHERE {
      GRAPH <${graphUri}> {
        ?rule ex:ruleName   ?name ;
              ex:ruleBody   ?body ;
              ex:ruleStatus ?status ;
              ex:ruleOrder  ?order .
      }
    }
    ORDER BY ASC(xsd:integer(?order))
  `;
  try {
    const res = await fetch(`${BACKEND_URL}/query/raw?dataset=${encodeURIComponent(datasetId)}`, {
      method: "POST",
      headers: { "Content-Type": "application/sparql-query" },
      body: sparql,
    });
    if (!res.ok) return [];
    const data = await res.json() as { results?: { bindings?: RuleBinding[] } };
    return data.results?.bindings ?? [];
  } catch { return []; }
}

const forwardGraph  = `urn:${datasetId}:tbox:rules:forward`;
const backwardGraph = `urn:${datasetId}:tbox:rules:backward`;

const [forwardRules, backwardRules] = await Promise.all([
  fetchRules(forwardGraph),
  fetchRules(backwardGraph),
]);
---

<BaseLayout title={`Rules — ${datasetId} — unconcealment`}>
  <DatasetNav datasetId={datasetId} current="rules" />

  <h1 style="font-family: 'Manrope', sans-serif; font-size: 1.75rem; font-weight: 800; color: #191c1e; letter-spacing: -0.025em; margin-bottom: 1.5rem;">
    Rules
  </h1>

  <!-- Forward Rules -->
  <section id="forward" style="margin-bottom: 2.5rem;">
    <div style="display: flex; align-items: baseline; gap: 0.5rem; margin-bottom: 0.375rem; padding-bottom: 0.5rem; border-bottom: 1px solid rgba(196,197,217,0.3);">
      <h2 style="font-family: 'Manrope', sans-serif; font-size: 1.125rem; font-weight: 700; color: #191c1e;">Forward Rules</h2>
      <span class="badge-count">{forwardRules.length}</span>
      <span style="font-size: 0.7rem; color: #c4c5d9; font-family: 'Inter', sans-serif;">materialized · RETE</span>
    </div>
    <code style="font-size: 0.7rem; color: #c4c5d9; display: block; margin-bottom: 0.875rem;">{forwardGraph}</code>

    {forwardRules.length === 0
      ? <EmptyState message="No forward rules found in graph." />
      : forwardRules.map(r => (
          <div
            style="background: #ffffff; border-radius: 1rem; margin-bottom: 0.625rem; overflow: hidden; box-shadow: 0px 4px 20px rgba(25,28,30,0.03), 0px 8px 24px rgba(18,74,240,0.04);"
          >
            <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.625rem 1.125rem; background: #f2f4f6;">
              <span style="font-family: ui-monospace, Menlo, Consolas, monospace; font-size: 0.7rem; color: #c4c5d9; min-width: 1.5rem;">#{r.order.value}</span>
              <span style="font-family: 'Manrope', sans-serif; font-size: 0.875rem; font-weight: 700; color: #191c1e; flex: 1;">{r.name.value}</span>
              <Chip label={r.status.value} variant={r.status.value === "active" ? "green" : "gray"} />
            </div>
            <div style="padding: 0.875rem 1.125rem;">
              <pre style="font-family: ui-monospace, Menlo, Consolas, monospace; font-size: 0.75rem; color: #434656; white-space: pre-wrap; word-break: break-words; line-height: 1.6;">{r.body.value.trim()}</pre>
            </div>
          </div>
        ))
    }
  </section>

  <!-- Backward Rules -->
  <section id="backward">
    <div style="display: flex; align-items: baseline; gap: 0.5rem; margin-bottom: 0.375rem; padding-bottom: 0.5rem; border-bottom: 1px solid rgba(196,197,217,0.3);">
      <h2 style="font-family: 'Manrope', sans-serif; font-size: 1.125rem; font-weight: 700; color: #191c1e;">Backward Rules</h2>
      <span class="badge-count">{backwardRules.length}</span>
      <span style="font-size: 0.7rem; color: #c4c5d9; font-family: 'Inter', sans-serif;">query-time · LP</span>
    </div>
    <code style="font-size: 0.7rem; color: #c4c5d9; display: block; margin-bottom: 0.875rem;">{backwardGraph}</code>

    {backwardRules.length === 0
      ? <EmptyState message="No backward rules found in graph." />
      : backwardRules.map(r => (
          <div
            style="background: #ffffff; border-radius: 1rem; margin-bottom: 0.625rem; overflow: hidden; box-shadow: 0px 4px 20px rgba(25,28,30,0.03), 0px 8px 24px rgba(18,74,240,0.04);"
          >
            <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.625rem 1.125rem; background: #f2f4f6;">
              <span style="font-family: ui-monospace, Menlo, Consolas, monospace; font-size: 0.7rem; color: #c4c5d9; min-width: 1.5rem;">#{r.order.value}</span>
              <span style="font-family: 'Manrope', sans-serif; font-size: 0.875rem; font-weight: 700; color: #191c1e; flex: 1;">{r.name.value}</span>
              <Chip label={r.status.value} variant={r.status.value === "active" ? "green" : "gray"} />
            </div>
            <div style="padding: 0.875rem 1.125rem;">
              <pre style="font-family: ui-monospace, Menlo, Consolas, monospace; font-size: 0.75rem; color: #434656; white-space: pre-wrap; word-break: break-words; line-height: 1.6;">{r.body.value.trim()}</pre>
            </div>
          </div>
        ))
    }
  </section>
</BaseLayout>
