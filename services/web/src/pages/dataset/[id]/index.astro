---
export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import DatasetNav from "../../../components/DatasetNav.astro";

const { id: datasetId } = Astro.params;
if (!datasetId) return Astro.redirect("/");

const BACKEND_URL = import.meta.env.BACKEND_URL ?? "http://localhost:8080";

const graphs = [
  { role: "Ontology",          uri: `urn:${datasetId}:tbox:ontology`,       href: `/dataset/${datasetId}/ontology`,       description: "OWL classes and properties",                       icon: "account_tree" },
  { role: "Forward Rules",     uri: `urn:${datasetId}:tbox:rules:forward`,  href: `/dataset/${datasetId}/rules#forward`,  description: "Materialized RETE rules",                          icon: "rule" },
  { role: "Backward Rules",    uri: `urn:${datasetId}:tbox:rules:backward`, href: `/dataset/${datasetId}/rules#backward`, description: "Query-time LP rules",                              icon: "rule" },
  { role: "Asserted Triples",  uri: `urn:${datasetId}:abox:asserted`,       href: `/dataset/${datasetId}/entities`,       description: "Extracted entities and relationships",             icon: "grain" },
  { role: "Documents",         uri: `urn:${datasetId}:abox:asserted`,       href: `/dataset/${datasetId}/documents`,      description: "Source documents referenced in provenance",        icon: "description",  hideCount: true },
  { role: "Inferred Triples",  uri: `urn:${datasetId}:abox:inferred`,       href: null,                                   description: "Materialized forward-chaining output (Phase 4)",   icon: "auto_awesome" },
  { role: "Normalization",     uri: `urn:${datasetId}:normalization`,        href: `/dataset/${datasetId}/normalization`,  description: "owl:sameAs links (Phase 2)",                        icon: "merge" },
  { role: "System Health",     uri: `urn:${datasetId}:system:health`,       href: null,                                   description: "Load events and ontology version lineage",          icon: "monitor_heart" },
  { role: "Reasoning",         uri: `urn:${datasetId}:abox:asserted`,       href: `/dataset/${datasetId}/reasoning`,      description: "Test custom backward-chaining rules at runtime",   icon: "psychology",  hideCount: true },
];

const countSparql = `
  SELECT ?graph (COUNT(*) AS ?count) WHERE {
    GRAPH ?graph { ?s ?p ?o }
  }
  GROUP BY ?graph
`;

interface CountBinding {
  graph: { value: string };
  count: { value: string };
}

let counts: Record<string, number> = {};
try {
  const res = await fetch(`${BACKEND_URL}/query/raw?dataset=${encodeURIComponent(datasetId)}`, {
    method: "POST",
    headers: { "Content-Type": "application/sparql-query" },
    body: countSparql,
  });
  if (res.ok) {
    const data = await res.json() as { results?: { bindings?: CountBinding[] } };
    for (const row of data.results?.bindings ?? []) {
      counts[row.graph.value] = parseInt(row.count.value, 10);
    }
  }
} catch { /* backend unavailable */ }
---

<BaseLayout title={`${datasetId} — unconcealment`}>
  <DatasetNav datasetId={datasetId} current="overview" />

  <!-- Page header -->
  <div style="margin-bottom: 1.75rem;">
    <span
      style="display: block; font-size: 0.625rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.2em; color: #0040e0; font-family: 'Inter', sans-serif; margin-bottom: 0.375rem;"
    >
      Named Graphs
    </span>
    <h1
      style="font-family: 'Manrope', sans-serif; font-size: 1.75rem; font-weight: 800; color: #191c1e; letter-spacing: -0.025em;"
    >
      {datasetId}
    </h1>
  </div>

  <!-- Graph cards grid -->
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(270px, 1fr)); gap: 0.875rem;">
    {graphs.map(g => {
      const count = counts[g.uri];
      const isAvailable = !!g.href;
      return isAvailable ? (
        <a
          href={g.href}
          style="display: block; background: #ffffff; border-radius: 1.25rem; padding: 1.25rem 1.375rem; text-decoration: none; transition: box-shadow 0.2s, transform 0.2s; box-shadow: 0px 4px 20px rgba(25,28,30,0.03), 0px 8px 24px rgba(18,74,240,0.04);"
          onmouseover="this.style.boxShadow='0px 4px 20px rgba(25,28,30,0.06), 0px 12px 40px rgba(18,74,240,0.09)';this.style.transform='translateY(-1px)'"
          onmouseout="this.style.boxShadow='0px 4px 20px rgba(25,28,30,0.03), 0px 8px 24px rgba(18,74,240,0.04)';this.style.transform='translateY(0)'"
        >
          <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 0.75rem; margin-bottom: 0.75rem;">
            <div
              style="width: 2rem; height: 2rem; border-radius: 0.625rem; background: #dde1ff; display: flex; align-items: center; justify-content: center; flex-shrink: 0;"
            >
              <span
                class="material-symbols-outlined"
                style="font-size: 0.9375rem; color: #0040e0; font-variation-settings: 'FILL' 0, 'wght' 400;"
              >
                {g.icon}
              </span>
            </div>
            {!g.hideCount && count !== undefined && (
              <span class="badge-count">{count.toLocaleString()}</span>
            )}
          </div>
          <h2
            style="font-family: 'Manrope', sans-serif; font-size: 0.9375rem; font-weight: 700; color: #191c1e; margin-bottom: 0.3rem;"
          >
            {g.role}
          </h2>
          <p style="font-size: 0.775rem; color: #747688; font-family: 'Inter', sans-serif; line-height: 1.45; margin-bottom: 0.5rem;">
            {g.description}
          </p>
          <code
            style="font-size: 0.65rem; color: #c4c5d9; font-family: ui-monospace, Menlo, Consolas, monospace; word-break: break-all; display: block;"
          >
            {g.uri}
          </code>
        </a>
      ) : (
        <div
          style="display: block; background: #f7f9fb; border-radius: 1.25rem; padding: 1.25rem 1.375rem; opacity: 0.45; cursor: not-allowed;"
        >
          <div style="display: flex; align-items: flex-start; gap: 0.75rem; margin-bottom: 0.75rem;">
            <div
              style="width: 2rem; height: 2rem; border-radius: 0.625rem; background: #eceef0; display: flex; align-items: center; justify-content: center; flex-shrink: 0;"
            >
              <span
                class="material-symbols-outlined"
                style="font-size: 0.9375rem; color: #747688; font-variation-settings: 'FILL' 0, 'wght' 300;"
              >
                {g.icon}
              </span>
            </div>
          </div>
          <h2
            style="font-family: 'Manrope', sans-serif; font-size: 0.9375rem; font-weight: 700; color: #191c1e; margin-bottom: 0.3rem;"
          >
            {g.role}
          </h2>
          <p style="font-size: 0.775rem; color: #747688; font-family: 'Inter', sans-serif; line-height: 1.45; margin-bottom: 0.5rem;">
            {g.description}
          </p>
          <code
            style="font-size: 0.65rem; color: #c4c5d9; font-family: ui-monospace, Menlo, Consolas, monospace; word-break: break-all; display: block;"
          >
            {g.uri}
          </code>
        </div>
      );
    })}
  </div>
</BaseLayout>
