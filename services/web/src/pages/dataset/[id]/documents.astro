---
export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import DatasetNav from "../../../components/DatasetNav.astro";
import DataTable from "../../../components/DataTable.astro";
import ErrorAlert from "../../../components/ErrorAlert.astro";
import EmptyState from "../../../components/EmptyState.astro";

const { id: datasetId } = Astro.params;
if (!datasetId) return Astro.redirect("/");

const BACKEND_URL = import.meta.env.BACKEND_URL ?? "http://localhost:8080";
const aboxAsserted = `urn:${datasetId}:abox:asserted`;

interface DocumentBinding {
  document: { value: string };
  tripleCount: { value: string };
}

const sparql = `
  PREFIX ex: <http://localhost:4321/ontology/>
  SELECT ?document (COUNT(*) AS ?tripleCount) WHERE {
    GRAPH <${aboxAsserted}> {
      << ?s ?p ?o >> ex:sourceDocument ?document .
    }
  }
  GROUP BY ?document
  ORDER BY DESC(?tripleCount) ?document
  LIMIT 500
`;

let docs: DocumentBinding[] = [];
let error: string | null = null;

try {
  const res = await fetch(`${BACKEND_URL}/query/raw?dataset=${encodeURIComponent(datasetId)}`, {
    method: "POST",
    headers: { "Content-Type": "application/sparql-query" },
    body: sparql,
  });
  if (res.ok) {
    const data = await res.json() as { results?: { bindings?: DocumentBinding[] } };
    docs = data.results?.bindings ?? [];
  } else {
    error = `Backend returned ${res.status}`;
  }
} catch {
  error = "Backend unavailable";
}

const keyFromDocumentIri = (iri: string) => iri.split("/").pop() ?? iri;
---

<BaseLayout title={`Documents — ${datasetId} — unconcealment`}>
  <DatasetNav datasetId={datasetId} current="documents" />

  <div style="margin-bottom: 1.5rem;">
    <div style="display: flex; align-items: baseline; gap: 0.625rem; margin-bottom: 0.25rem;">
      <h1 style="font-family: 'Manrope', sans-serif; font-size: 1.75rem; font-weight: 800; color: #191c1e; letter-spacing: -0.025em;">
        Documents
      </h1>
      {docs.length > 0 && <span class="badge-count">{docs.length}</span>}
    </div>
    <p style="font-size: 0.75rem; color: #747688;">Provenance source documents from <code style="color: #c4c5d9;">{aboxAsserted}</code></p>
  </div>

  {error && <ErrorAlert message={`Query failed: ${error}`} />}
  {!error && docs.length === 0 && <EmptyState message="No source documents found in provenance annotations yet." />}

  {docs.length > 0 && (
    <DataTable columns={["Document", "Triples Referencing", "Document IRI"]}>
      {docs.map(row => {
        const iri = row.document.value;
        const key = keyFromDocumentIri(iri);
        return (
          <tr>
            <td><a class="link-primary" href={`/document/${encodeURIComponent(key)}?dataset=${encodeURIComponent(datasetId)}`}>{key}</a></td>
            <td style="color: #747688;">{Number(row.tripleCount.value).toLocaleString()}</td>
            <td style="font-family: ui-monospace, Menlo, Consolas, monospace; font-size: 0.7rem; color: #c4c5d9; word-break: break-all;">{iri}</td>
          </tr>
        );
      })}
    </DataTable>
  )}
</BaseLayout>
