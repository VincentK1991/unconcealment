---
export const prerender = false;

import DatasetNav from "../../../components/DatasetNav.astro";
import ReasoningPlayground from "../../../components/ReasoningPlayground.tsx";

const { id: datasetId } = Astro.params;
if (!datasetId) return Astro.redirect("/");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reasoning Playground — {datasetId} — unconcealment</title>
    <style>
      body { font-family: system-ui, sans-serif; max-width: 1100px; margin: 2rem auto; padding: 0 1rem; }
      h1 { font-size: 1.5rem; margin: 0 0 0.25rem; }
      .subtitle { color: #555; font-size: 0.9rem; margin: 0 0 1.5rem; }
    </style>
  </head>
  <body>
    <DatasetNav datasetId={datasetId} current="reasoning" />
    <h1>Reasoning Playground</h1>
    <p class="subtitle">
      Write custom Jena backward-chaining rules and test them against the live graph at runtime.
      Rules are ephemeral — not stored in the rule graph.
    </p>

    <ReasoningPlayground client:load datasetId={datasetId} />
  </body>
</html>
