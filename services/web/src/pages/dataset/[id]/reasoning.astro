---
export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import DatasetNav from "../../../components/DatasetNav.astro";
import ReasoningPlayground from "../../../components/ReasoningPlayground.tsx";

const { id: datasetId } = Astro.params;
if (!datasetId) return Astro.redirect("/");
---

<BaseLayout title={`Reasoning Playground — ${datasetId} — unconcealment`} width="full">
  <DatasetNav datasetId={datasetId} current="reasoning" />

  <div style="margin-bottom: 1.5rem;">
    <h1 style="font-family: 'Manrope', sans-serif; font-size: 1.75rem; font-weight: 800; color: #191c1e; letter-spacing: -0.025em; margin-bottom: 0.375rem;">
      Reasoning Playground
    </h1>
    <p style="font-size: 0.875rem; color: #747688; font-family: 'Inter', sans-serif; max-width: 42rem; line-height: 1.6;">
      Write custom Jena backward-chaining rules and test them against the live graph at runtime.
      Rules are ephemeral — not stored in the rule graph.
    </p>
  </div>

  <ReasoningPlayground client:load datasetId={datasetId} />
</BaseLayout>
