---
export const prerender = false;

import { readFileSync } from "fs";
import { parse } from "yaml";
import path from "path";
import { fileURLToPath } from "url";

import BaseLayout from "../../../layouts/BaseLayout.astro";
import DatasetNav from "../../../components/DatasetNav.astro";
import SqlExplorer from "../../../components/SqlExplorer.tsx";

const { id: datasetId } = Astro.params;
if (!datasetId) return Astro.redirect("/");

// Load manifest to validate postgres is enabled for this dataset.
const __dirname = path.dirname(fileURLToPath(import.meta.url));
const manifestPath =
  import.meta.env.MANIFEST_PATH ??
  path.resolve(__dirname, "../../../../../ontology/manifest.yaml");

const manifest = parse(readFileSync(manifestPath, "utf8")) as {
  datasets: Array<{ id: string; label?: string; postgres?: { enabled?: boolean; schema?: string } }>;
};
const datasetConfig = manifest.datasets.find((d) => d.id === datasetId);

if (!datasetConfig?.postgres?.enabled) {
  return Astro.redirect(`/dataset/${datasetId}`);
}

const schema = datasetConfig.postgres?.schema ?? "public";
const label = datasetConfig.label ?? datasetId;
---

<BaseLayout title={`SQL — ${label} — unconcealment`} width="full">
  <DatasetNav datasetId={datasetId} current="sql" />

  <div style="margin-bottom: 1.5rem;">
    <h1 style="font-family: 'Manrope', sans-serif; font-size: 1.75rem; font-weight: 800; color: #191c1e; letter-spacing: -0.025em; margin-bottom: 0.375rem;">
      SQL Explorer
    </h1>
    <p style="font-size: 0.875rem; color: #747688; font-family: 'Inter', sans-serif; max-width: 42rem; line-height: 1.6;">
      Execute SELECT queries against the <code style="font-family: 'JetBrains Mono', monospace; font-size: 0.8125rem; background: #f3f4f8; padding: 0.1em 0.35em; border-radius: 0.25rem;">{schema}</code> PostgreSQL schema.
      Results are capped at 500 rows.
    </p>
    <div style="margin-top: 0.5rem;">
      <code style="font-size: 0.75rem; color: #747688; font-family: 'JetBrains Mono', monospace;">
        postgres-kg / {schema}
      </code>
    </div>
  </div>

  <SqlExplorer client:load datasetId={datasetId} schema={schema} />
</BaseLayout>
