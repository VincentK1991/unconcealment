---
// Canonical entity page. The UUID IRI is the stable, permanent identifier.
// Backward compatibility: if an old slug URL is requested, resolve slug -> UUID and redirect.
// Supports content negotiation: Accept: text/html → this page
// TODO (Phase 1): add Accept: application/ld+json → JSON-LD response
//                           Accept: text/turtle    → Turtle response

export const prerender = false;

import EntityGraph from "../../../components/EntityGraph.tsx";

const { uuid: entityIdParam, dataset: datasetId } = Astro.params;
if (!entityIdParam || !datasetId) return Astro.redirect("/");
const aboxAsserted = `urn:${datasetId}:abox:asserted`;
const aboxInferred = `urn:${datasetId}:abox:inferred`;
const normGraph    = `urn:${datasetId}:normalization`;

const BACKEND_URL = import.meta.env.BACKEND_URL ?? "http://localhost:8080";
const BASE_URI = import.meta.env.BASE_URI;
let entityIri = BASE_URI ? `${BASE_URI}/entity/${datasetId}/${entityIdParam}` : "";

interface Triple {
  p: { value: string };
  o: { value: string; type: string };
}
interface PeerTriple {
  source: { value: string };
  p: { value: string };
  o: { value: string; type: string };
}
interface ProvenanceBinding {
  document: { value: string };
  tripleCount: { value: string };
}
interface IncomingTriple {
  s: { value: string };
  p: { value: string };
}
interface PeerIncomingTriple {
  peer: { value: string };
  s: { value: string };
  p: { value: string };
}
interface EntityDisplayMeta {
  label?: { value: string };
  slug?: { value: string };
}

const RDFS_LABEL   = "http://www.w3.org/2000/01/rdf-schema#label";
const RDFS_COMMENT = "http://www.w3.org/2000/01/rdf-schema#comment";
const EX_SLUG      = "https://kg.unconcealment.io/ontology/slug";

let titleText = entityIdParam;
let triples: Triple[] = [];
let incomingTriples: IncomingTriple[] = [];
let peerTriples: PeerTriple[] = [];
let peerIncomingTriples: PeerIncomingTriple[] = [];
let entityDescription: string | null = null;
let error: string | null = null;
const escapedEntityIdParam = entityIdParam.replace(/\\/g, "\\\\").replace(/"/g, "\\\"");
const escapedEntityPathSuffix = `/entity/${datasetId}/${escapedEntityIdParam}`;
let canonicalUuid = entityIdParam;
let entitySlug: string | null = null;
const objectDisplayMap = new Map<string, { label?: string; slug?: string }>();
let provenanceDocs: ProvenanceBinding[] = [];
let sameAsIris: string[] = [];
const sameAsDisplayMap = new Map<string, { label?: string; slug?: string }>();
let isCanonical = false;
let canonicalIri: string | null = null;

// Fetch the entity's own asserted (+ forward-materialized) triples — no sameAs inference.
async function fetchTriples(subjectIri: string): Promise<Triple[]> {
  const sparql = `
    SELECT ?p ?o WHERE {
      GRAPH ?g {
        <${subjectIri}> ?p ?o .
      }
      FILTER(?g IN (<${aboxAsserted}>, <${aboxInferred}>))
    }
    LIMIT 100
  `;
  const res = await fetch(
    `${BACKEND_URL}/query/raw?dataset=${encodeURIComponent(datasetId)}`,
    {
      method: "POST",
      headers: { "Content-Type": "application/sparql-query" },
      body: sparql,
    }
  );
  if (!res.ok) return [];
  const data = await res.json() as { results?: { bindings?: Triple[] } };
  return data?.results?.bindings ?? [];
}

// Fetch properties of all sameAs cluster peers using SPARQL 1.1 property paths against Fuseki.
// (owl:sameAs|^owl:sameAs)+ traverses the normalization graph in both directions transitively,
// so indirect peers and reverse edges are all included. This avoids the Jena InfModel entirely —
// Fuseki's native SPARQL engine handles the path traversal correctly and cheaply.
async function fetchPeerTriples(subjectIri: string): Promise<PeerTriple[]> {
  const sparql = `
    PREFIX owl: <http://www.w3.org/2002/07/owl#>
    SELECT DISTINCT ?source ?p ?o WHERE {
      GRAPH <${normGraph}> {
        <${subjectIri}> (owl:sameAs|^owl:sameAs)+ ?source .
        FILTER(?source != <${subjectIri}>)
      }
      GRAPH <${aboxAsserted}> {
        ?source ?p ?o .
        FILTER(isIRI(?source))
      }
      FILTER(?p != owl:sameAs)
    }
    LIMIT 200
  `;
  const res = await fetch(
    `${BACKEND_URL}/query/raw?dataset=${encodeURIComponent(datasetId)}`,
    {
      method: "POST",
      headers: { "Content-Type": "application/sparql-query" },
      body: sparql,
    }
  );
  if (!res.ok) return [];
  const data = await res.json() as { results?: { bindings?: PeerTriple[] } };
  return data?.results?.bindings ?? [];
}

async function fetchEntityDisplayMeta(iris: string[]): Promise<Map<string, { label?: string; slug?: string }>> {
  const map = new Map<string, { label?: string; slug?: string }>();
  if (iris.length === 0) return map;

  const values = iris.map((iri) => `<${iri}>`).join(" ");
  const sparql = `
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    PREFIX ex:   <https://kg.unconcealment.io/ontology/>
    SELECT ?entity ?label ?slug WHERE {
      GRAPH ?g {
        VALUES ?entity { ${values} }
        OPTIONAL { ?entity rdfs:label ?label }
        OPTIONAL { ?entity ex:slug ?slug }
      }
      FILTER(?g IN (<${aboxAsserted}>, <${aboxInferred}>))
    }
  `;

  const res = await fetch(`${BACKEND_URL}/query/raw?dataset=${encodeURIComponent(datasetId)}`, {
    method: "POST",
    headers: { "Content-Type": "application/sparql-query" },
    body: sparql,
  });
  if (!res.ok) return map;

  const data = await res.json() as { results?: { bindings?: Array<{ entity?: { value: string }; label?: { value: string }; slug?: { value: string } }> } };
  for (const row of data?.results?.bindings ?? []) {
    const iri = row.entity?.value;
    if (!iri) continue;
    const current = map.get(iri) ?? {};
    if (row.label?.value) current.label = row.label.value;
    if (row.slug?.value) current.slug = row.slug.value;
    map.set(iri, current);
  }
  return map;
}

async function fetchSameAsLinks(subjectIri: string): Promise<string[]> {
  const sparql = `
    PREFIX owl: <http://www.w3.org/2002/07/owl#>
    SELECT DISTINCT ?other WHERE {
      GRAPH <${normGraph}> {
        { <${subjectIri}> owl:sameAs ?other }
        UNION
        { ?other owl:sameAs <${subjectIri}> }
      }
    }
  `;
  const res = await fetch(`${BACKEND_URL}/query/raw?dataset=${encodeURIComponent(datasetId)}`, {
    method: "POST",
    headers: { "Content-Type": "application/sparql-query" },
    body: sparql,
  });
  if (!res.ok) return [];
  const data = await res.json() as { results?: { bindings?: Array<{ other?: { value: string } }> } };
  return (data?.results?.bindings ?? []).map(b => b.other?.value).filter(Boolean) as string[];
}

// Predicates that are too noisy or already shown elsewhere when appearing as incoming
const INCOMING_FILTER_PREDICATES = [
  "http://www.w3.org/2002/07/owl#sameAs",
].map(p => `<${p}>`).join(", ");

async function fetchIncomingTriples(subjectIri: string): Promise<IncomingTriple[]> {
  const sparql = `
    PREFIX owl: <http://www.w3.org/2002/07/owl#>
    SELECT DISTINCT ?s ?p WHERE {
      GRAPH ?g {
        ?s ?p <${subjectIri}> .
        FILTER(isIRI(?s))
        FILTER(?p NOT IN (${INCOMING_FILTER_PREDICATES}))
      }
      FILTER(?g IN (<${aboxAsserted}>, <${aboxInferred}>))
    }
    ORDER BY ?p ?s
    LIMIT 100
  `;
  const res = await fetch(`${BACKEND_URL}/query/raw?dataset=${encodeURIComponent(datasetId)}`, {
    method: "POST",
    headers: { "Content-Type": "application/sparql-query" },
    body: sparql,
  });
  if (!res.ok) return [];
  const data = await res.json() as { results?: { bindings?: IncomingTriple[] } };
  return data?.results?.bindings ?? [];
}

async function fetchPeerIncomingTriples(subjectIri: string): Promise<PeerIncomingTriple[]> {
  const sparql = `
    PREFIX owl: <http://www.w3.org/2002/07/owl#>
    SELECT DISTINCT ?s ?p ?peer WHERE {
      GRAPH <${normGraph}> {
        <${subjectIri}> (owl:sameAs|^owl:sameAs)+ ?peer .
        FILTER(?peer != <${subjectIri}>)
      }
      GRAPH <${aboxAsserted}> {
        ?s ?p ?peer .
        FILTER(isIRI(?s))
        FILTER(?p NOT IN (${INCOMING_FILTER_PREDICATES}))
      }
    }
    ORDER BY ?peer ?p ?s
    LIMIT 200
  `;
  const res = await fetch(`${BACKEND_URL}/query/raw?dataset=${encodeURIComponent(datasetId)}`, {
    method: "POST",
    headers: { "Content-Type": "application/sparql-query" },
    body: sparql,
  });
  if (!res.ok) return [];
  const data = await res.json() as { results?: { bindings?: PeerIncomingTriple[] } };
  return data?.results?.bindings ?? [];
}

const iriTail = (iri: string) => iri.split(/[/#]/).pop() ?? iri;
const linkPathFromIri = (iri: string): string => {
  if (iri.includes("/document/")) {
    const key = iriTail(iri);
    return `/document/${encodeURIComponent(key)}?dataset=${encodeURIComponent(datasetId)}`;
  }
  const id = iriTail(iri);
  return `/entity/${encodeURIComponent(datasetId)}/${encodeURIComponent(id)}`;
};

try {
  // First attempt: query using configured BASE_URI (if available).
  if (entityIri) {
    triples = await fetchTriples(entityIri);
  }

  // Fallback: resolve canonical subject IRI from graph by UUID/path suffix.
  if (triples.length === 0) {
    const resolveIriSparql = `
      SELECT ?entity WHERE {
        GRAPH ?g {
          ?entity ?p ?o .
        }
        FILTER(?g IN (<${aboxAsserted}>, <${aboxInferred}>))
        FILTER(STRENDS(STR(?entity), "${escapedEntityPathSuffix}"))
      }
      LIMIT 1
    `;
    const resolveRes = await fetch(
      `${BACKEND_URL}/query/raw?dataset=${encodeURIComponent(datasetId)}`,
      {
        method: "POST",
        headers: { "Content-Type": "application/sparql-query" },
        body: resolveIriSparql,
      }
    );
    if (resolveRes.ok) {
      const resolveData = await resolveRes.json() as { results?: { bindings?: Array<{ entity?: { value: string } }> } };
      const resolvedEntityIri = resolveData?.results?.bindings?.[0]?.entity?.value ?? null;
      if (resolvedEntityIri) {
        entityIri = resolvedEntityIri;
        triples = await fetchTriples(entityIri);
      }
    }
  }

  if (entityIri) {
    canonicalUuid = entityIri.split("/").pop() ?? entityIdParam;
  }

  const labelTriple       = triples.find((t) => t.p.value === RDFS_LABEL   && t.o.type !== "uri");
  const slugTriple        = triples.find((t) => t.p.value === EX_SLUG      && t.o.type !== "uri");
  const descriptionTriple = triples.find((t) => t.p.value === RDFS_COMMENT && t.o.type !== "uri");
  entitySlug        = slugTriple?.o.value ?? null;
  entityDescription = descriptionTriple?.o.value ?? null;
  titleText = labelTriple?.o.value ?? entitySlug ?? canonicalUuid;

  const objectIris = Array.from(
    new Set(
      triples
        .filter((t) => t.o.type === "uri")
        .map((t) => t.o.value)
    )
  );
  const objectMeta = await fetchEntityDisplayMeta(objectIris);
  for (const [iri, meta] of objectMeta.entries()) {
    objectDisplayMap.set(iri, meta);
  }

  // Fetch incoming triples (this entity as object) in parallel with provenance
  if (entityIri) {
    incomingTriples = await fetchIncomingTriples(entityIri);
    const incomingSubjectIris = Array.from(new Set(incomingTriples.map(t => t.s.value)));
    if (incomingSubjectIris.length > 0) {
      const incomingMeta = await fetchEntityDisplayMeta(incomingSubjectIris);
      for (const [iri, meta] of incomingMeta.entries()) {
        objectDisplayMap.set(iri, meta);
      }
    }
  }

  if (entityIri) {
    const provenanceSparql = `
      PREFIX ex: <https://kg.unconcealment.io/ontology/>
      SELECT ?document (COUNT(*) AS ?tripleCount) WHERE {
        GRAPH <${aboxAsserted}> {
          {
            << <${entityIri}> ?p ?o >> ex:sourceDocument ?document .
          }
          UNION
          {
            << ?s ?p <${entityIri}> >> ex:sourceDocument ?document .
          }
        }
      }
      GROUP BY ?document
      ORDER BY DESC(?tripleCount) ?document
      LIMIT 100
    `;
    const provRes = await fetch(`${BACKEND_URL}/query/raw?dataset=${encodeURIComponent(datasetId)}`, {
      method: "POST",
      headers: { "Content-Type": "application/sparql-query" },
      body: provenanceSparql,
    });
    if (provRes.ok) {
      const provData = await provRes.json() as { results?: { bindings?: ProvenanceBinding[] } };
      provenanceDocs = provData.results?.bindings ?? [];
    }
  }
  if (entityIri) {
    sameAsIris = await fetchSameAsLinks(entityIri);
    if (sameAsIris.length > 0) {
      const sameAsMeta = await fetchEntityDisplayMeta(sameAsIris);
      for (const [iri, meta] of sameAsMeta.entries()) {
        sameAsDisplayMap.set(iri, meta);
      }
    }
  }

  // Determine canonical status and fetch peer triples for the "With sameAs" tab.
  if (entityIri && sameAsIris.length > 0) {
    // Determine whether this entity is the canonical representative or a member.
    const canonInfoSparql = `
      PREFIX ex:  <https://kg.unconcealment.io/ontology/>
      PREFIX owl: <http://www.w3.org/2002/07/owl#>
      SELECT ?isCanonical ?canonical WHERE {
        GRAPH <${normGraph}> {
          OPTIONAL { <${entityIri}> ex:isCanonical ?isCanonical }
          OPTIONAL {
            { <${entityIri}> owl:sameAs ?canonical } UNION { ?canonical owl:sameAs <${entityIri}> }
            ?canonical ex:isCanonical true .
            FILTER(?canonical != <${entityIri}>)
          }
        }
      }
      LIMIT 1
    `;
    const canonRes = await fetch(`${BACKEND_URL}/query/raw?dataset=${encodeURIComponent(datasetId)}`, {
      method: "POST",
      headers: { "Content-Type": "application/sparql-query" },
      body: canonInfoSparql,
    });
    if (canonRes.ok) {
      const canonData = await canonRes.json() as {
        results?: { bindings?: Array<{ isCanonical?: { value: string }; canonical?: { value: string } }> }
      };
      const row = canonData?.results?.bindings?.[0];
      isCanonical = row?.isCanonical?.value === "true";
      canonicalIri = row?.canonical?.value ?? null;
      // If this entity is canonical, its own IRI is the canonical.
      if (isCanonical) canonicalIri = entityIri;
    }

    // Fetch cluster peer outgoing + incoming triples.
    peerTriples = await fetchPeerTriples(entityIri);
    peerIncomingTriples = await fetchPeerIncomingTriples(entityIri);
    // Collect all IRIs needed for display metadata.
    const peerSourceIris = Array.from(new Set(peerTriples.map(t => t.source.value)));
    const peerObjectIris = Array.from(
      new Set(peerTriples.filter(t => t.o.type === "uri").map(t => t.o.value))
    );
    const peerIncomingSubjectIris = Array.from(new Set(peerIncomingTriples.map(t => t.s.value)));
    const peerIncomingTargetIris  = Array.from(new Set(peerIncomingTriples.map(t => t.peer.value)));
    const allPeerIris = [...peerSourceIris, ...peerObjectIris, ...peerIncomingSubjectIris, ...peerIncomingTargetIris];
    if (allPeerIris.length > 0) {
      const peerMeta = await fetchEntityDisplayMeta(allPeerIris);
      for (const [iri, meta] of peerMeta.entries()) {
        objectDisplayMap.set(iri, meta);
      }
    }
  }
} catch (e) {
  console.error(e);
  error = "Backend unavailable";
}

const shortPredicate = (iri: string) => iri.split(/[/#]/).pop() ?? iri;

// Seed data for the EntityGraph island — IRI-to-IRI edges only, literals excluded.
// sameAs peers are treated as equivalent to the central entity (full equivalence),
// so their outgoing/incoming neighbors are also included at degree 1.
const seedEdges = [
  ...triples
    .filter((t) => t.o.type === "uri")
    .map((t) => ({ source: entityIri, target: t.o.value, predicate: t.p.value })),
  ...peerTriples
    .filter((t) => t.o.type === "uri")
    .map((t) => ({ source: t.source.value, target: t.o.value, predicate: t.p.value })),
];

const seedIncoming = [
  ...incomingTriples.map((t) => ({
    source: t.s.value,
    target: entityIri,
    predicate: t.p.value,
  })),
  ...peerIncomingTriples.map((t) => ({
    source: t.s.value,
    target: t.peer.value,
    predicate: t.p.value,
  })),
];

// Flatten objectDisplayMap to a plain object (Map is not JSON-serializable for islands)
const seedLabels: Record<string, string> = {};
for (const [iri, meta] of objectDisplayMap.entries()) {
  if (meta.label) seedLabels[iri] = meta.label;
  else if (meta.slug) seedLabels[iri] = meta.slug;
}
// Merge sameAs display labels into seedLabels
for (const [iri, meta] of sameAsDisplayMap.entries()) {
  if (!seedLabels[iri]) {
    if (meta.label) seedLabels[iri] = meta.label;
    else if (meta.slug) seedLabels[iri] = meta.slug;
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{titleText} — unconcealment</title>
    <style>
      body { font-family: system-ui, sans-serif; max-width: 860px; margin: 2rem auto; padding: 0 1rem; }
      h1 { font-size: 1.6rem; }
      .iri { font-size: 0.8rem; color: #777; word-break: break-all; }
      .description { margin: 0.6rem 0 0.4rem; color: #333; line-height: 1.5; }
      .meta { margin: 0.5rem 0 1rem; background: #f8f8f8; border: 1px solid #e5e5e5; border-radius: 8px; padding: 0.6rem 0.8rem; font-size: 0.85rem; }
      .meta-row { margin: 0.15rem 0; }
      .meta-key { color: #666; font-weight: 600; margin-right: 0.35rem; }
      .section-title { margin-top: 1.25rem; margin-bottom: 0.5rem; font-size: 1.05rem; }
      .prov-list { margin: 0.35rem 0 0.9rem; padding-left: 1.2rem; }
      .prov-list li { margin: 0.3rem 0; }
      .prov-count { color: #666; font-size: 0.85rem; margin-left: 0.35rem; }
      table { width: 100%; border-collapse: collapse; margin-top: 1.5rem; }
      th { text-align: left; border-bottom: 2px solid #ccc; padding: 0.4rem 0.6rem; }
      td { padding: 0.4rem 0.6rem; border-bottom: 1px solid #eee; vertical-align: top; }
      td:first-child { color: #555; width: 30%; }
      .error { color: #c00; }
      .same-as-list { list-style: none; padding: 0; margin: 0.35rem 0 0.9rem; display: flex; flex-wrap: wrap; gap: 0.4rem; }
      .same-as-chip { display: inline-block; background: #eef3fb; border: 1px solid #b3cde8; border-radius: 4px; padding: 0.2rem 0.55rem; font-size: 0.875rem; color: #1a6bb5; text-decoration: none; }
      .same-as-chip:hover { background: #dce8f7; }
      .canonical-banner { margin: 0.6rem 0 0.8rem; padding: 0.5rem 0.8rem; background: #fffbe6; border: 1px solid #ffe58f; border-radius: 6px; font-size: 0.875rem; }
      .canonical-banner a { color: #7c5e00; font-weight: 600; }
      .tabs { display: flex; gap: 0; margin-top: 1.5rem; border-bottom: 2px solid #ccc; }
      .tab-btn { padding: 0.45rem 1rem; border: none; background: none; cursor: pointer; font-size: 0.9rem; color: #666; border-bottom: 3px solid transparent; margin-bottom: -2px; }
      .tab-btn.active { color: #1a6bb5; border-bottom-color: #1a6bb5; font-weight: 600; }
      .tab-btn:hover:not(.active) { background: #f5f5f5; }
      .tab-panel { display: none; }
      .tab-panel.active { display: block; }
      .source-tag { font-size: 0.75rem; color: #888; margin-left: 0.4rem; }
      .source-tag a { color: #888; }
      .subsection-title { margin-top: 1.5rem; margin-bottom: 0.25rem; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #888; }
    </style>
  </head>
  <body>
    <a href={`/dataset/${encodeURIComponent(datasetId)}`}>← Dataset</a>
    <h1>{titleText}</h1>
    <p class="iri">{entityIri || `(unresolved for ${entityIdParam})`}</p>
    {entityDescription && <p class="description">{entityDescription}</p>}
    <div class="meta">
      <div class="meta-row"><span class="meta-key">ID:</span><code>{entityIdParam}</code></div>
      {entitySlug && <div class="meta-row"><span class="meta-key">Slug:</span><code>{entitySlug}</code></div>}
    </div>

    {/* Canonical banner — shown only when this entity is a non-canonical cluster member */}
    {!isCanonical && canonicalIri && canonicalIri !== entityIri && (
      <div class="canonical-banner">
        ⚑ This entity is merged with&nbsp;
        <a href={linkPathFromIri(canonicalIri)}>
          {sameAsDisplayMap.get(canonicalIri)?.label ?? iriTail(canonicalIri)} [canonical]
        </a>
      </div>
    )}

    {sameAsIris.length > 0 && (
      <>
        <h2 class="section-title">Also Known As</h2>
        <ul class="same-as-list">
          {sameAsIris.map((iri) => (
            <li>
              <a class="same-as-chip" href={linkPathFromIri(iri)}>
                {sameAsDisplayMap.get(iri)?.label ?? sameAsDisplayMap.get(iri)?.slug ?? iriTail(iri)}
              </a>
            </li>
          ))}
        </ul>
      </>
    )}

    <h2 class="section-title">Provenance Documents</h2>
    {provenanceDocs.length > 0 ? (
      <ul class="prov-list">
        {provenanceDocs.map((row) => {
          const documentIri = row.document.value;
          const documentKey = iriTail(documentIri);
          return (
            <li>
              <a href={`/document/${encodeURIComponent(documentKey)}?dataset=${encodeURIComponent(datasetId)}`}>{documentKey}</a>
              <span class="prov-count">({Number(row.tripleCount.value).toLocaleString()} triple(s))</span>
            </li>
          );
        })}
      </ul>
    ) : (
      <p>No source document provenance found for this entity.</p>
    )}

    {error && <p class="error">{error} — showing stub page</p>}

    {/* Tab bar — only show the sameAs tab when there are cluster peers with properties */}
    <div class="tabs">
      <button class="tab-btn active" data-tab="raw">Properties</button>
      {(peerTriples.length > 0 || peerIncomingTriples.length > 0) && (
        <button class="tab-btn" data-tab="reasoned">With sameAs ({peerTriples.length + peerIncomingTriples.length} triples)</button>
      )}
      {entityIri && (
        <button class="tab-btn" data-tab="graph">Graph</button>
      )}
    </div>

    {/* Tab: asserted properties (no sameAs inference) */}
    <div class="tab-panel active" id="tab-raw">
      <h3 class="subsection-title">References</h3>
      {triples.length > 0 ? (
        <table>
          <thead>
            <tr>
              <th>Predicate</th>
              <th>Object</th>
            </tr>
          </thead>
          <tbody>
            {triples.map((t) => (
              <tr>
                <td title={t.p.value}>{shortPredicate(t.p.value)}</td>
                <td>
                  {t.o.type === "uri" ? (
                    <a href={linkPathFromIri(t.o.value)}>
                      {objectDisplayMap.get(t.o.value)?.label ?? objectDisplayMap.get(t.o.value)?.slug ?? iriTail(t.o.value)}
                    </a>
                  ) : (
                    t.o.value
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : (
        !error && <p>No properties found for this entity.</p>
      )}

      <h3 class="subsection-title">Referenced by</h3>
      {incomingTriples.length > 0 ? (
        <table>
          <thead>
            <tr>
              <th>Subject</th>
              <th>Predicate</th>
            </tr>
          </thead>
          <tbody>
            {incomingTriples.map((t) => (
              <tr>
                <td>
                  <a href={linkPathFromIri(t.s.value)}>
                    {objectDisplayMap.get(t.s.value)?.label ?? objectDisplayMap.get(t.s.value)?.slug ?? iriTail(t.s.value)}
                  </a>
                </td>
                <td title={t.p.value}>{shortPredicate(t.p.value)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : (
        !error && <p style="color:#aaa;font-size:0.85rem">No incoming references found.</p>
      )}
    </div>

    {/* Tab: merged cluster view (sameAs outgoing + incoming) */}
    {(peerTriples.length > 0 || peerIncomingTriples.length > 0) && (
      <div class="tab-panel" id="tab-reasoned">
        <h3 class="subsection-title">References (cluster)</h3>
        {(triples.length > 0 || peerTriples.length > 0) ? (
          <table>
            <thead>
              <tr>
                <th>Predicate</th>
                <th>Value</th>
                <th>Source</th>
              </tr>
            </thead>
            <tbody>
              {/* Own triples first */}
              {triples.map((t) => (
                <tr>
                  <td title={t.p.value}>{shortPredicate(t.p.value)}</td>
                  <td>
                    {t.o.type === "uri" ? (
                      <a href={linkPathFromIri(t.o.value)}>
                        {objectDisplayMap.get(t.o.value)?.label ?? objectDisplayMap.get(t.o.value)?.slug ?? iriTail(t.o.value)}
                      </a>
                    ) : (
                      t.o.value
                    )}
                  </td>
                  <td><span class="source-tag">this entity</span></td>
                </tr>
              ))}
              {/* Peer triples from sameAs cluster members */}
              {peerTriples.map((t) => (
                <tr>
                  <td title={t.p.value}>{shortPredicate(t.p.value)}</td>
                  <td>
                    {t.o.type === "uri" ? (
                      <a href={linkPathFromIri(t.o.value)}>
                        {objectDisplayMap.get(t.o.value)?.label ?? objectDisplayMap.get(t.o.value)?.slug ?? iriTail(t.o.value)}
                      </a>
                    ) : (
                      t.o.value
                    )}
                  </td>
                  <td>
                    <span class="source-tag">
                      from <a href={linkPathFromIri(t.source.value)}>
                        {objectDisplayMap.get(t.source.value)?.label ?? iriTail(t.source.value)}
                      </a>
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        ) : (
          <p style="color:#aaa;font-size:0.85rem">No outgoing properties in cluster.</p>
        )}

        <h3 class="subsection-title">Referenced by (cluster)</h3>
        {(incomingTriples.length > 0 || peerIncomingTriples.length > 0) ? (
          <table>
            <thead>
              <tr>
                <th>Subject</th>
                <th>Predicate</th>
                <th>Target</th>
              </tr>
            </thead>
            <tbody>
              {/* Own incoming */}
              {incomingTriples.map((t) => (
                <tr>
                  <td>
                    <a href={linkPathFromIri(t.s.value)}>
                      {objectDisplayMap.get(t.s.value)?.label ?? objectDisplayMap.get(t.s.value)?.slug ?? iriTail(t.s.value)}
                    </a>
                  </td>
                  <td title={t.p.value}>{shortPredicate(t.p.value)}</td>
                  <td><span class="source-tag">this entity</span></td>
                </tr>
              ))}
              {/* Peer incoming */}
              {peerIncomingTriples.map((t) => (
                <tr>
                  <td>
                    <a href={linkPathFromIri(t.s.value)}>
                      {objectDisplayMap.get(t.s.value)?.label ?? objectDisplayMap.get(t.s.value)?.slug ?? iriTail(t.s.value)}
                    </a>
                  </td>
                  <td title={t.p.value}>{shortPredicate(t.p.value)}</td>
                  <td>
                    <span class="source-tag">
                      &#8594; <a href={linkPathFromIri(t.peer.value)}>
                        {objectDisplayMap.get(t.peer.value)?.label ?? iriTail(t.peer.value)}
                      </a>
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        ) : (
          <p style="color:#aaa;font-size:0.85rem">No incoming references in cluster.</p>
        )}
      </div>
    )}

    {/* Graph tab panel — EntityGraph island, lazy-hydrated on idle */}
    {entityIri && (
      <div class="tab-panel" id="tab-graph" style="padding-top: 1rem; width: 100vw; position: relative; left: 50%; transform: translateX(-50%);">
        <EntityGraph
          client:idle
          entityIri={entityIri}
          entityLabel={titleText}
          datasetId={datasetId}
          seedEdges={seedEdges}
          seedIncoming={seedIncoming}
          seedLabels={seedLabels}
          sameAsIris={sameAsIris}
        />
      </div>
    )}

    <script>
      document.querySelectorAll<HTMLButtonElement>('.tab-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
          document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
          btn.classList.add('active');
          const panel = document.getElementById('tab-' + btn.dataset.tab);
          if (panel) panel.classList.add('active');
        });
      });
    </script>
  </body>
</html>
