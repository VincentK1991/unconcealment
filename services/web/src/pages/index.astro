---
// Landing page — lists available datasets from the manifest
import { readFileSync } from "fs";
import { parse } from "yaml";
import path from "path";

const manifestPath = process.env.MANIFEST_PATH
  ?? path.resolve(process.cwd(), "../../ontology/manifest.yaml");

let datasets: Array<{ id: string; label: string; description: string }> = [];
try {
  const raw = readFileSync(manifestPath, "utf8");
  const manifest = parse(raw) as { datasets: typeof datasets };
  datasets = manifest.datasets;
} catch {
  // manifest not found at dev time — show placeholder
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>unconcealment — Knowledge Graph</title>
    <style>
      body { font-family: system-ui, sans-serif; max-width: 860px; margin: 2rem auto; padding: 0 1rem; }
      h1 { font-size: 1.8rem; margin-bottom: 0.25rem; }
      p.tagline { color: #555; margin-top: 0; }
      .datasets { display: grid; gap: 1rem; margin-top: 2rem; }
      .dataset-card {
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 1rem 1.25rem;
        text-decoration: none;
        color: inherit;
        display: block;
      }
      .dataset-card:hover { border-color: #888; background: #fafafa; }
      .dataset-card h2 { margin: 0 0 0.25rem; font-size: 1.1rem; }
      .dataset-card p { margin: 0; color: #555; font-size: 0.9rem; }
    </style>
  </head>
  <body>
    <h1>unconcealment</h1>
    <p class="tagline">A metadata-driven semantic knowledge graph</p>

    <h2>Datasets</h2>
    {datasets.length === 0 && (
      <p>No datasets found. Check that <code>ontology/manifest.yaml</code> is accessible.</p>
    )}
    <div class="datasets">
      {datasets.map((ds) => (
        <a class="dataset-card" href={`/dataset/${ds.id}`}>
          <h2>{ds.label}</h2>
          <p>{ds.description}</p>
        </a>
      ))}
    </div>
  </body>
</html>
