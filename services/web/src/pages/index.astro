---
import { readFileSync } from "fs";
import { parse } from "yaml";
import path from "path";
import BaseLayout from "../layouts/BaseLayout.astro";

const manifestPath = process.env.MANIFEST_PATH
  ?? path.resolve(process.cwd(), "../../ontology/manifest.yaml");

let datasets: Array<{ id: string; label: string; description: string }> = [];
try {
  const raw = readFileSync(manifestPath, "utf8");
  const manifest = parse(raw) as { datasets: typeof datasets };
  datasets = manifest.datasets;
} catch {
  // manifest not found at dev time — show placeholder
}
---

<BaseLayout title="unconcealment — Knowledge Graph" width="narrow">
  <!-- Page header -->
  <div style="margin-bottom: 2.5rem;">
    <span
      style="display: block; font-size: 0.625rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.2em; color: #0040e0; font-family: 'Inter', sans-serif; margin-bottom: 0.5rem;"
    >
      Knowledge Graph Explorer
    </span>
    <h1
      style="font-family: 'Manrope', sans-serif; font-size: 2rem; font-weight: 800; color: #191c1e; letter-spacing: -0.03em; line-height: 1.15; margin-bottom: 0.5rem;"
    >
      Datasets
    </h1>
    <p style="font-size: 0.9375rem; color: #747688; font-family: 'Inter', sans-serif;">
      A metadata-driven semantic knowledge graph. Select a dataset to explore.
    </p>
  </div>

  <!-- Dataset cards -->
  {datasets.length === 0 && (
    <div
      style="text-align: center; padding: 3rem 1rem; background: #ffffff; border-radius: 1.5rem; box-shadow: 0px 4px 20px rgba(25,28,30,0.04), 0px 12px 40px rgba(18,74,240,0.06);"
    >
      <span
        class="material-symbols-outlined"
        style="font-size: 2.5rem; color: #c4c5d9; display: block; margin-bottom: 0.75rem; font-variation-settings: 'FILL' 0, 'wght' 300;"
      >
        folder_open
      </span>
      <p style="font-size: 0.9rem; color: #747688; font-family: 'Inter', sans-serif;">
        No datasets found. Check that <code>ontology/manifest.yaml</code> is accessible.
      </p>
    </div>
  )}

  <div style="display: grid; gap: 0.875rem;">
    {datasets.map((ds) => (
      <a
        href={`/dataset/${ds.id}`}
        style="display: block; background: #ffffff; border-radius: 1.25rem; padding: 1.25rem 1.5rem; text-decoration: none; transition: box-shadow 0.2s, transform 0.2s; box-shadow: 0px 4px 20px rgba(25,28,30,0.04), 0px 12px 40px rgba(18,74,240,0.04);"
        onmouseover="this.style.boxShadow='0px 4px 20px rgba(25,28,30,0.06), 0px 12px 40px rgba(18,74,240,0.1)';this.style.transform='translateY(-1px)'"
        onmouseout="this.style.boxShadow='0px 4px 20px rgba(25,28,30,0.04), 0px 12px 40px rgba(18,74,240,0.04)';this.style.transform='translateY(0)'"
      >
        <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem;">
          <div style="display: flex; align-items: flex-start; gap: 1rem;">
            <div
              style="width: 2.5rem; height: 2.5rem; border-radius: 0.75rem; background: #dde1ff; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 0.125rem;"
            >
              <span
                class="material-symbols-outlined"
                style="font-size: 1.125rem; color: #0040e0; font-variation-settings: 'FILL' 0, 'wght' 400;"
              >
                dataset
              </span>
            </div>
            <div>
              <h2
                style="font-family: 'Manrope', sans-serif; font-size: 1rem; font-weight: 700; color: #191c1e; letter-spacing: -0.01em; margin-bottom: 0.3rem;"
              >
                {ds.label}
              </h2>
              <p style="font-size: 0.8125rem; color: #747688; font-family: 'Inter', sans-serif; line-height: 1.5;">
                {ds.description}
              </p>
              <code
                style="font-size: 0.7rem; color: #c4c5d9; font-family: ui-monospace, Menlo, Consolas, monospace; display: block; margin-top: 0.375rem;"
              >
                {ds.id}
              </code>
            </div>
          </div>
          <span
            class="material-symbols-outlined"
            style="font-size: 1.125rem; color: #c4c5d9; flex-shrink: 0; margin-top: 0.25rem; font-variation-settings: 'FILL' 0, 'wght' 300;"
          >
            arrow_forward
          </span>
        </div>
      </a>
    ))}
  </div>
</BaseLayout>
