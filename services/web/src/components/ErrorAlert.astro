---
interface Props {
  message: string;
}
const { message } = Astro.props;
---

<div
  role="alert"
  style="display: flex; align-items: flex-start; gap: 0.75rem; padding: 0.875rem 1.125rem; border-radius: 0.75rem; background: #ffdad6; color: #93000a; font-size: 0.875rem; margin-bottom: 1rem; font-family: 'Inter', sans-serif;"
>
  <span
    class="material-symbols-outlined"
    style="font-size: 1.125rem; flex-shrink: 0; margin-top: 0.05rem; font-variation-settings: 'FILL' 0, 'wght' 500;"
  >
    error
  </span>
  <span>{message}</span>
</div>
