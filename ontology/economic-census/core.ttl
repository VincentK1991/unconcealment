@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix ex:   <http://localhost:4321/ontology/> .

# ============================================================
# Ontology: Economic & Census Data
# Dataset:  economic-census
# Status:   Phase 1 stub — classes and properties are additive-first
# ============================================================

<http://localhost:4321/ontology/economic-census>
    a owl:Ontology ;
    rdfs:label "Economic & Census Data Ontology" ;
    owl:versionInfo "0.2.0" .

# ------------------------------------------------------------
# Core Infrastructure Classes (shared pattern across datasets)
# ------------------------------------------------------------

ex:Entity
    a owl:Class ;
    rdfs:label "Entity" ;
    rdfs:comment "Top-level class for all real-world individuals in this dataset." .

ex:Document
    a owl:Class ;
    rdfs:label "Document" ;
    rdfs:comment "A source document from which triples are extracted. Referenced in provenance." .

# ------------------------------------------------------------
# Geographic / Census Classes
# ------------------------------------------------------------

ex:GeographicArea
    a owl:Class ;
    rdfs:subClassOf ex:Entity ;
    rdfs:label "Geographic Area" ;
    rdfs:comment "Any geographic unit: country, state, county, tract, block group." .

ex:Country
    a owl:Class ;
    rdfs:subClassOf ex:GeographicArea ;
    rdfs:label "Country" .

ex:State
    a owl:Class ;
    rdfs:subClassOf ex:GeographicArea ;
    rdfs:label "State" .

ex:County
    a owl:Class ;
    rdfs:subClassOf ex:GeographicArea ;
    rdfs:label "County" .

ex:CensusRegion
    a owl:Class ;
    rdfs:subClassOf ex:GeographicArea ;
    rdfs:label "Census Region" ;
    rdfs:comment "Official US Census Bureau region (Northeast, Midwest, South, West)." .

ex:CensusTract
    a owl:Class ;
    rdfs:subClassOf ex:GeographicArea ;
    rdfs:label "Census Tract" ;
    rdfs:comment "Small, relatively permanent statistical subdivision of a county." .

# ------------------------------------------------------------
# Economic Classes
# ------------------------------------------------------------

ex:EconomicIndicator
    a owl:Class ;
    rdfs:subClassOf ex:Entity ;
    rdfs:label "Economic Indicator" ;
    rdfs:comment "A measurable economic variable (GDP, unemployment rate, median income, etc.)." .

ex:Organization
    a owl:Class ;
    rdfs:subClassOf ex:Entity ;
    rdfs:label "Organization" ;
    rdfs:comment "A company, government agency, non-profit, or other organized body." .

ex:IndustrySector
    a owl:Class ;
    rdfs:subClassOf ex:Entity ;
    rdfs:label "Industry Sector" ;
    rdfs:comment "An economic industry classification, typically represented by a NAICS code and title." .

ex:BusinessEstablishment
    a owl:Class ;
    rdfs:subClassOf ex:Entity ;
    rdfs:label "Business Establishment" ;
    rdfs:comment "A business location or operating unit represented in economic census data." .

ex:Household
    a owl:Class ;
    rdfs:subClassOf ex:Entity ;
    rdfs:label "Household" ;
    rdfs:comment "A census household unit used for housing, income, and poverty-related measures." .

ex:LaborForceStatus
    a owl:Class ;
    rdfs:subClassOf ex:Entity ;
    rdfs:label "Labor Force Status" ;
    rdfs:comment "Employment status category such as employed, unemployed, or not in labor force." .

# ------------------------------------------------------------
# Core Object Properties
# ------------------------------------------------------------

ex:inRegion
    a owl:ObjectProperty ;
    rdfs:domain ex:Entity ;
    rdfs:range  ex:GeographicArea ;
    rdfs:label "in region" .

ex:partOf
    a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:domain ex:GeographicArea ;
    rdfs:range  ex:GeographicArea ;
    rdfs:label "part of" .

ex:relatedTo
    a owl:ObjectProperty, owl:SymmetricProperty ;
    rdfs:domain ex:Entity ;
    rdfs:range  ex:Entity ;
    rdfs:label "related to" .

ex:sourceDocument
    a owl:ObjectProperty ;
    rdfs:domain ex:Entity ;
    rdfs:range  ex:Document ;
    rdfs:label "source document" .

ex:inIndustry
    a owl:ObjectProperty ;
    rdfs:domain ex:BusinessEstablishment ;
    rdfs:range  ex:IndustrySector ;
    rdfs:label "in industry" ;
    rdfs:comment "Associates a business establishment with an industry sector." .

ex:hasLaborForceStatus
    a owl:ObjectProperty ;
    rdfs:domain ex:PopulationGroup ;
    rdfs:range  ex:LaborForceStatus ;
    rdfs:label "has labor force status" ;
    rdfs:comment "Associates a population group with a labor force status category." .

# ------------------------------------------------------------
# Core Datatype Properties
# ------------------------------------------------------------

ex:hasValue
    a owl:DatatypeProperty ;
    rdfs:domain ex:EconomicIndicator ;
    rdfs:range  xsd:decimal ;
    rdfs:label "has value" .

ex:forYear
    a owl:DatatypeProperty ;
    rdfs:domain ex:EconomicIndicator ;
    rdfs:range  xsd:gYear ;
    rdfs:label "for year" .

ex:geoid
    a owl:DatatypeProperty ;
    rdfs:domain ex:GeographicArea ;
    rdfs:range  xsd:string ;
    rdfs:label "GEOID" ;
    rdfs:comment "US Census Bureau GEOID identifier." .

ex:fipsCode
    a owl:DatatypeProperty ;
    rdfs:domain ex:GeographicArea ;
    rdfs:range  xsd:string ;
    rdfs:label "FIPS code" .

ex:naicsCode
    a owl:DatatypeProperty ;
    rdfs:domain ex:IndustrySector ;
    rdfs:range  xsd:string ;
    rdfs:label "NAICS code" ;
    rdfs:comment "North American Industry Classification System code." .

ex:householdSize
    a owl:DatatypeProperty ;
    rdfs:domain ex:Household ;
    rdfs:range  xsd:decimal ;
    rdfs:label "household size" ;
    rdfs:comment "Number of persons in the household." .

ex:slug
    a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "slug" ;
    rdfs:comment "Human-readable URL slug. Convenience alias; canonical IRI is the UUID form." .

ex:mintedAt
    a owl:DatatypeProperty ;
    rdfs:range xsd:dateTime ;
    rdfs:label "minted at" .

ex:mintedFrom
    a owl:ObjectProperty ;
    rdfs:range ex:Document ;
    rdfs:label "minted from" .

# ------------------------------------------------------------
# Bi-Temporal + Provenance Properties (applied via RDF-star)
# ------------------------------------------------------------

ex:validFrom
    a owl:DatatypeProperty ;
    rdfs:range xsd:dateTime ;
    rdfs:label "valid from" ;
    rdfs:comment "Start of the interval during which the fact was true in the world." .

ex:validTo
    a owl:DatatypeProperty ;
    rdfs:range xsd:dateTime ;
    rdfs:label "valid to" ;
    rdfs:comment "End of valid time. Open interval if absent." .

ex:transactionTime
    a owl:DatatypeProperty ;
    rdfs:range xsd:dateTime ;
    rdfs:label "transaction time" ;
    rdfs:comment "When the triple was recorded in the graph." .

ex:confidence
    a owl:DatatypeProperty ;
    rdfs:range xsd:decimal ;
    rdfs:label "confidence" ;
    rdfs:comment "Extraction confidence score [0.0–1.0]." .

ex:extractionMethod
    a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "extraction method" ;
    rdfs:comment "E.g. 'llm:gpt-4o', 'rule-based-nlp'." .

ex:extractedAt
    a owl:DatatypeProperty ;
    rdfs:range xsd:dateTime ;
    rdfs:label "extracted at" .

# ------------------------------------------------------------
# Statistical Observation Classes (Census / QB-aligned)
# ------------------------------------------------------------

ex:StatisticalObservation
    a owl:Class ;
    rdfs:subClassOf ex:Entity ;
    rdfs:label "Statistical Observation" ;
    rdfs:comment "A single summary statistic from a census document. Use observationValue for the numeric value, marginOfError for the MOE, referenceYear (xsd:gYear) for the year the statistic describes, confidenceLevel (e.g. '90 percent') for the significance threshold, changeFromPriorYear for the year-over-year delta, and changeDirection ('increase'|'decrease'|'no_significant_change') for the direction of change. Link to a geographic area with refersToGeography, to a demographic subgroup with refersToGroup (omit for total population), to the measure concept with measures, to the source survey with derivedFrom, and to the report document with reportedIn." .

ex:PopulationGroup
    a owl:Class ;
    rdfs:subClassOf ex:Entity ;
    rdfs:label "Population Group" ;
    rdfs:comment "A demographic subgroup that a statistical observation applies to. characteristicType values: 'age'|'sex'|'race'|'ethnicity'|'nativity'|'poverty_status'|'insurance_status'|'household_type'. characteristicValue is the human-readable label (e.g. '65 and over', 'Hispanic or Latino', 'Below poverty threshold', 'Foreign-born'). Use ombCode for the OMB race or ethnicity classification code where applicable." .

ex:CensusSurvey
    a owl:Class ;
    rdfs:subClassOf ex:Entity ;
    rdfs:label "Census Survey" ;
    rdfs:comment "A Census Bureau survey program and vintage that produced statistical observations. surveyName values: 'American Community Survey', 'Current Population Survey ASEC', 'Survey of Income and Program Participation', 'Decennial Census', 'National Population Projections'. surveyVintage is the reference year as xsd:gYear. surveyMethodology values: '1-year estimates', '5-year estimates', 'cohort-component'." .

ex:StatisticalMeasure
    a owl:Class ;
    rdfs:subClassOf ex:Entity ;
    rdfs:label "Statistical Measure" ;
    rdfs:comment "A named measure concept describing what is being counted or calculated. measureName examples: 'povertyRate', 'medianHouseholdIncome', 'totalPopulation', 'populationGrowthRate', 'medianAge', 'raceCompositionShare', 'apportionmentPopulation', 'projectedPopulation', 'naturalIncrease', 'netInternationalMigration', 'healthInsuranceCoverageRate', 'uninsuredRate', 'congressionalSeats'. measureUnit values: 'percent', 'dollars', 'persons', 'years', 'seats'. measureType values: 'rate'|'count'|'median'|'mean'|'ratio'|'projection'." .

ex:MetropolitanStatisticalArea
    a owl:Class ;
    rdfs:subClassOf ex:GeographicArea ;
    rdfs:label "Metropolitan Statistical Area" ;
    rdfs:comment "An OMB-defined metropolitan statistical area (MSA) containing a core urban area with 50,000 or more people. Use cbsaCode for the numeric CBSA code (e.g. '33460' for Minneapolis-St. Paul MSA) and rdfs:label for the human-readable name." .

ex:ReportDocument
    a owl:Class ;
    rdfs:subClassOf ex:Document ;
    rdfs:label "Report Document" ;
    rdfs:comment "A published Census Bureau report from which observations are extracted. seriesCode is the report identifier (e.g. 'c2020br-01', 'acsbr-022', 'p60-284', 'p25-1144', 'p70-212'). publicationDate is an xsd:date. Use sourceDocument to link extracted entities back to this report." .

# ------------------------------------------------------------
# Statistical Observation Object Properties
# ------------------------------------------------------------

ex:refersToGeography
    a owl:ObjectProperty ;
    rdfs:domain ex:StatisticalObservation ;
    rdfs:range  ex:GeographicArea ;
    rdfs:label "refers to geography" ;
    rdfs:comment "The geographic area this observation describes (nation, state, county, MSA, etc.)." .

ex:refersToGroup
    a owl:ObjectProperty ;
    rdfs:domain ex:StatisticalObservation ;
    rdfs:range  ex:PopulationGroup ;
    rdfs:label "refers to group" ;
    rdfs:comment "The demographic subgroup this observation applies to. Omit if the observation covers the total population." .

ex:measures
    a owl:ObjectProperty ;
    rdfs:domain ex:StatisticalObservation ;
    rdfs:range  ex:StatisticalMeasure ;
    rdfs:label "measures" ;
    rdfs:comment "The named measure concept being reported (e.g. povertyRate, medianHouseholdIncome)." .

ex:derivedFrom
    a owl:ObjectProperty ;
    rdfs:domain ex:StatisticalObservation ;
    rdfs:range  ex:CensusSurvey ;
    rdfs:label "derived from" ;
    rdfs:comment "The census survey program and vintage that produced this observation." .

ex:reportedIn
    a owl:ObjectProperty ;
    rdfs:domain ex:StatisticalObservation ;
    rdfs:range  ex:ReportDocument ;
    rdfs:label "reported in" ;
    rdfs:comment "The specific report document where this observation was published." .

# ------------------------------------------------------------
# Statistical Observation Datatype Properties
# ------------------------------------------------------------

ex:observationValue
    a owl:DatatypeProperty ;
    rdfs:domain ex:StatisticalObservation ;
    rdfs:range  xsd:decimal ;
    rdfs:label "observation value" ;
    rdfs:comment "The numeric value of the statistic (e.g. 12.5 for a 12.5% poverty rate)." .

ex:marginOfError
    a owl:DatatypeProperty ;
    rdfs:domain ex:StatisticalObservation ;
    rdfs:range  xsd:decimal ;
    rdfs:label "margin of error" ;
    rdfs:comment "The margin of error for the estimate at the reported confidence level." .

ex:referenceYear
    a owl:DatatypeProperty ;
    rdfs:domain ex:StatisticalObservation ;
    rdfs:range  xsd:gYear ;
    rdfs:label "reference year" ;
    rdfs:comment "The calendar year the statistic describes (e.g. '2023'^^xsd:gYear)." .

ex:confidenceLevel
    a owl:DatatypeProperty ;
    rdfs:domain ex:StatisticalObservation ;
    rdfs:range  xsd:string ;
    rdfs:label "confidence level" ;
    rdfs:comment "The statistical confidence level for significance testing (e.g. '90 percent')." .

ex:changeFromPriorYear
    a owl:DatatypeProperty ;
    rdfs:domain ex:StatisticalObservation ;
    rdfs:range  xsd:decimal ;
    rdfs:label "change from prior year" ;
    rdfs:comment "The year-over-year change in the observation value (signed decimal)." .

ex:changeDirection
    a owl:DatatypeProperty ;
    rdfs:domain ex:StatisticalObservation ;
    rdfs:range  xsd:string ;
    rdfs:label "change direction" ;
    rdfs:comment "Direction of year-over-year change. Values: 'increase'|'decrease'|'no_significant_change'." .

# ------------------------------------------------------------
# Population Group Datatype Properties
# ------------------------------------------------------------

ex:characteristicType
    a owl:DatatypeProperty ;
    rdfs:domain ex:PopulationGroup ;
    rdfs:range  xsd:string ;
    rdfs:label "characteristic type" ;
    rdfs:comment "The demographic dimension being described. Values: 'age'|'sex'|'race'|'ethnicity'|'nativity'|'poverty_status'|'insurance_status'|'household_type'." .

ex:characteristicValue
    a owl:DatatypeProperty ;
    rdfs:domain ex:PopulationGroup ;
    rdfs:range  xsd:string ;
    rdfs:label "characteristic value" ;
    rdfs:comment "Human-readable label for the characteristic (e.g. '65 and over', 'Hispanic or Latino', 'Below poverty threshold', 'Foreign-born', 'Uninsured')." .

ex:ombCode
    a owl:DatatypeProperty ;
    rdfs:domain ex:PopulationGroup ;
    rdfs:range  xsd:string ;
    rdfs:label "OMB code" ;
    rdfs:comment "OMB race or ethnicity classification code where applicable." .

# ------------------------------------------------------------
# Census Survey Datatype Properties
# ------------------------------------------------------------

ex:surveyName
    a owl:DatatypeProperty ;
    rdfs:domain ex:CensusSurvey ;
    rdfs:range  xsd:string ;
    rdfs:label "survey name" ;
    rdfs:comment "Name of the census survey program (e.g. 'American Community Survey', 'Current Population Survey ASEC', 'Survey of Income and Program Participation', 'Decennial Census')." .

ex:surveyVintage
    a owl:DatatypeProperty ;
    rdfs:domain ex:CensusSurvey ;
    rdfs:range  xsd:gYear ;
    rdfs:label "survey vintage" ;
    rdfs:comment "The reference year of this survey edition (e.g. '2023'^^xsd:gYear)." .

ex:surveyMethodology
    a owl:DatatypeProperty ;
    rdfs:domain ex:CensusSurvey ;
    rdfs:range  xsd:string ;
    rdfs:label "survey methodology" ;
    rdfs:comment "Estimation methodology (e.g. '1-year estimates', '5-year estimates', 'cohort-component', 'full enumeration')." .

# ------------------------------------------------------------
# Statistical Measure Datatype Properties
# ------------------------------------------------------------

ex:measureName
    a owl:DatatypeProperty ;
    rdfs:domain ex:StatisticalMeasure ;
    rdfs:range  xsd:string ;
    rdfs:label "measure name" ;
    rdfs:comment "Canonical camelCase name for the measure (e.g. 'povertyRate', 'medianHouseholdIncome', 'totalPopulation', 'healthInsuranceCoverageRate', 'apportionmentPopulation', 'netInternationalMigration', 'congressionalSeats')." .

ex:measureUnit
    a owl:DatatypeProperty ;
    rdfs:domain ex:StatisticalMeasure ;
    rdfs:range  xsd:string ;
    rdfs:label "measure unit" ;
    rdfs:comment "Unit of measurement. Values: 'percent', 'dollars', 'persons', 'years', 'seats'." .

ex:measureType
    a owl:DatatypeProperty ;
    rdfs:domain ex:StatisticalMeasure ;
    rdfs:range  xsd:string ;
    rdfs:label "measure type" ;
    rdfs:comment "Statistical type of the measure. Values: 'rate'|'count'|'median'|'mean'|'ratio'|'projection'." .

# ------------------------------------------------------------
# Report Document Datatype Properties
# ------------------------------------------------------------

ex:seriesCode
    a owl:DatatypeProperty ;
    rdfs:domain ex:ReportDocument ;
    rdfs:range  xsd:string ;
    rdfs:label "series code" ;
    rdfs:comment "Census Bureau series and document code (e.g. 'c2020br-01', 'acsbr-022', 'p60-284', 'p25-1144', 'p70-212', 'ft895-24')." .

ex:publicationDate
    a owl:DatatypeProperty ;
    rdfs:domain ex:ReportDocument ;
    rdfs:range  xsd:date ;
    rdfs:label "publication date" ;
    rdfs:comment "Date the report was published (xsd:date)." .

# ------------------------------------------------------------
# Metropolitan Statistical Area Datatype Properties
# ------------------------------------------------------------

ex:cbsaCode
    a owl:DatatypeProperty ;
    rdfs:domain ex:MetropolitanStatisticalArea ;
    rdfs:range  xsd:string ;
    rdfs:label "CBSA code" ;
    rdfs:comment "OMB Core-Based Statistical Area numeric code (e.g. '33460' for Minneapolis-St. Paul MSA)." .

# ============================================================
# ACS Socioeconomic Datatype Properties
# Source: census_bureau_acs.county_*yr / state_*yr
# Domain: ex:GeographicArea (county or state level)
# ============================================================

ex:totalPop
    a owl:DatatypeProperty ;
    rdfs:domain ex:GeographicArea ;
    rdfs:range  xsd:decimal ;
    rdfs:label "total population" ;
    rdfs:comment "Total population count (ACS estimate)." .

ex:medianIncome
    a owl:DatatypeProperty ;
    rdfs:domain ex:GeographicArea ;
    rdfs:range  xsd:decimal ;
    rdfs:label "median household income" ;
    rdfs:comment "Median household income, inflation-adjusted dollars (ACS)." .

ex:incomePerCapita
    a owl:DatatypeProperty ;
    rdfs:domain ex:GeographicArea ;
    rdfs:range  xsd:decimal ;
    rdfs:label "income per capita" ;
    rdfs:comment "Per capita income, dollars (ACS)." .

ex:povertyCount
    a owl:DatatypeProperty ;
    rdfs:domain ex:GeographicArea ;
    rdfs:range  xsd:decimal ;
    rdfs:label "poverty population count" ;
    rdfs:comment "Population count below the federal poverty level (ACS)." .

ex:unemployedPop
    a owl:DatatypeProperty ;
    rdfs:domain ex:GeographicArea ;
    rdfs:range  xsd:decimal ;
    rdfs:label "unemployed population" ;
    rdfs:comment "Unemployed population count (ACS)." .

ex:giniIndex
    a owl:DatatypeProperty ;
    rdfs:domain ex:GeographicArea ;
    rdfs:range  xsd:decimal ;
    rdfs:label "Gini index" ;
    rdfs:comment "Gini coefficient of income inequality [0–1]. Higher = more unequal (ACS)." .

ex:rentBurdenPercent
    a owl:DatatypeProperty ;
    rdfs:domain ex:GeographicArea ;
    rdfs:range  xsd:decimal ;
    rdfs:label "rent burden percent" ;
    rdfs:comment "Median gross rent as percentage of household income (ACS)." .

ex:medianRent
    a owl:DatatypeProperty ;
    rdfs:domain ex:GeographicArea ;
    rdfs:range  xsd:decimal ;
    rdfs:label "median rent" ;
    rdfs:comment "Median gross rent, dollars per month (ACS)." .

ex:medianHomeValue
    a owl:DatatypeProperty ;
    rdfs:domain ex:GeographicArea ;
    rdfs:range  xsd:decimal ;
    rdfs:label "median home value" ;
    rdfs:comment "Median value of owner-occupied housing units, dollars (ACS)." .

ex:medianAge
    a owl:DatatypeProperty ;
    rdfs:domain ex:GeographicArea ;
    rdfs:range  xsd:decimal ;
    rdfs:label "median age" ;
    rdfs:comment "Median age of population (ACS)." .

ex:whitePop
    a owl:DatatypeProperty ;
    rdfs:domain ex:GeographicArea ;
    rdfs:range  xsd:decimal ;
    rdfs:label "white non-Hispanic population" ;
    rdfs:comment "White non-Hispanic population count (ACS)." .

ex:blackPop
    a owl:DatatypeProperty ;
    rdfs:domain ex:GeographicArea ;
    rdfs:range  xsd:decimal ;
    rdfs:label "Black/African American population" ;
    rdfs:comment "Black or African American population count (ACS)." .

ex:hispanicPop
    a owl:DatatypeProperty ;
    rdfs:domain ex:GeographicArea ;
    rdfs:range  xsd:decimal ;
    rdfs:label "Hispanic/Latino population" ;
    rdfs:comment "Hispanic or Latino population count (ACS)." .

ex:asianPop
    a owl:DatatypeProperty ;
    rdfs:domain ex:GeographicArea ;
    rdfs:range  xsd:decimal ;
    rdfs:label "Asian population" ;
    rdfs:comment "Asian population count (ACS)." .

ex:collegeDegreePopulation
    a owl:DatatypeProperty ;
    rdfs:domain ex:GeographicArea ;
    rdfs:range  xsd:decimal ;
    rdfs:label "college degree population (25–64)" ;
    rdfs:comment "Population aged 25–64 with a bachelor's degree or higher (ACS)." .

ex:lessHighSchoolPopulation
    a owl:DatatypeProperty ;
    rdfs:domain ex:GeographicArea ;
    rdfs:range  xsd:decimal ;
    rdfs:label "less than high school population" ;
    rdfs:comment "Population 25+ without a high school diploma (ACS)." .

ex:employedManufacturing
    a owl:DatatypeProperty ;
    rdfs:domain ex:GeographicArea ;
    rdfs:range  xsd:decimal ;
    rdfs:label "employed in manufacturing" ;
    rdfs:comment "Workers employed in manufacturing (ACS)." .

ex:employedEducationHealth
    a owl:DatatypeProperty ;
    rdfs:domain ex:GeographicArea ;
    rdfs:range  xsd:decimal ;
    rdfs:label "employed in education/health/social" ;
    rdfs:comment "Workers employed in education, health, and social services (ACS)." .

ex:commutersPublicTransit
    a owl:DatatypeProperty ;
    rdfs:domain ex:GeographicArea ;
    rdfs:range  xsd:decimal ;
    rdfs:label "commuters by public transit" ;
    rdfs:comment "Workers who commute by public transportation (ACS)." .

ex:workedAtHome
    a owl:DatatypeProperty ;
    rdfs:domain ex:GeographicArea ;
    rdfs:range  xsd:decimal ;
    rdfs:label "worked at home" ;
    rdfs:comment "Workers who worked from home (ACS)." .

# ============================================================
# Opportunity Atlas Mobility & Structural Properties
# Source: census_opportunity_atlas.tract_outcomes / tract_covariates
# Domain: ex:CensusTract
# ============================================================

ex:upwardMobilityP25
    a owl:DatatypeProperty ;
    rdfs:domain ex:CensusTract ;
    rdfs:range  xsd:decimal ;
    rdfs:label "upward mobility index (p25, pooled)" ;
    rdfs:comment "Mean family income rank at age 35 for ALL children whose parents were at the 25th income percentile. Primary Opportunity Atlas upward mobility metric (kfr_pooled_pooled_p25)." .

ex:upwardMobilityBlackP25
    a owl:DatatypeProperty ;
    rdfs:domain ex:CensusTract ;
    rdfs:range  xsd:decimal ;
    rdfs:label "upward mobility index (p25, Black)" ;
    rdfs:comment "Mean family income rank for Black children from p25 families (kfr_black_pooled_p25)." .

ex:upwardMobilityWhiteP25
    a owl:DatatypeProperty ;
    rdfs:domain ex:CensusTract ;
    rdfs:range  xsd:decimal ;
    rdfs:label "upward mobility index (p25, white)" ;
    rdfs:comment "Mean family income rank for white children from p25 families (kfr_white_pooled_p25)." .

ex:upwardMobilityHispanicP25
    a owl:DatatypeProperty ;
    rdfs:domain ex:CensusTract ;
    rdfs:range  xsd:decimal ;
    rdfs:label "upward mobility index (p25, Hispanic)" ;
    rdfs:comment "Mean family income rank for Hispanic children from p25 families (kfr_hisp_pooled_p25)." .

ex:incarcerationRate
    a owl:DatatypeProperty ;
    rdfs:domain ex:CensusTract ;
    rdfs:range  xsd:decimal ;
    rdfs:label "incarceration rate (pooled)" ;
    rdfs:comment "Fraction of all children incarcerated on April 1, 2010 (jail_pooled_pooled_mean)." .

ex:incarcerationRateBlackMale
    a owl:DatatypeProperty ;
    rdfs:domain ex:CensusTract ;
    rdfs:range  xsd:decimal ;
    rdfs:label "incarceration rate (Black male)" ;
    rdfs:comment "Fraction of Black males incarcerated — key racial disparity metric (jail_black_male_mean)." .

ex:marriageRateFemale
    a owl:DatatypeProperty ;
    rdfs:domain ex:CensusTract ;
    rdfs:range  xsd:decimal ;
    rdfs:label "marriage rate (female)" ;
    rdfs:comment "Fraction of women who are married in 2015 (married_pooled_female_mean)." .

ex:employmentRate
    a owl:DatatypeProperty ;
    rdfs:domain ex:CensusTract ;
    rdfs:range  xsd:decimal ;
    rdfs:label "employment rate" ;
    rdfs:comment "Fraction of children who have positive W-2 income (working_pooled_pooled_mean)." .

ex:teenBirthRateFemale
    a owl:DatatypeProperty ;
    rdfs:domain ex:CensusTract ;
    rdfs:range  xsd:decimal ;
    rdfs:label "teen birth rate (female)" ;
    rdfs:comment "Fraction of women who had a child before age 20 (teenbrth_pooled_female_mean)." .

ex:commutingZoneName
    a owl:DatatypeProperty ;
    rdfs:domain ex:CensusTract ;
